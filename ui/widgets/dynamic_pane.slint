import { Slider } from "std-widgets.slint";
import { LeftTabEntry, DevicePropEntry, ProjectTreeEntry, FileEntry } from "../types.slint";
import { RangeSlider } from "range_slider.slint";

export component DynamicPane inherits Rectangle {
    // ── Tab management ────────────────────────────────────────────────────────
    in-out property <[LeftTabEntry]> tabs;
    in-out property <int> active-tab: 0;
    out property <int> active-tab-type:
        (root.active-tab < root.tabs.length) ? root.tabs[root.active-tab].tab-type : -1;
    in property <int> current-area: 0;  // 0=Left 1=RightTop 2=RightBottom
    callback close-tab(int);
    callback move-tab(int, int);  // (tab_idx, target_area)

    // ── Tab3d (type_id 0) ─────────────────────────────────────────────────────
    in property <image> teapot-image;
    callback viewer3d-panned(float, float);
    callback viewer3d-scrolled(float);

    // ── Tab2d (type_id 1) ─────────────────────────────────────────────────────
    in property <image> viewer2d-image;
    in-out property <bool>  viewer2d-image-loaded: false;
    in-out property <float> viewer2d-lo: 0.0;
    in-out property <float> viewer2d-hi: 255.0;
    in-out property <float> viewer2d-z: 0;
    in-out property <float> viewer2d-z-max: 0;
    in property <[ProjectTreeEntry]> project-tree;
    callback viewer2d-panned(float, float);
    callback viewer2d-scrolled(float);
    callback viewer2d-settings-changed();
    callback viewer2d-z-changed(float);
    callback viewer2d-object-selected(int, int);

    // ── TabCamera (type_id 2) ─────────────────────────────────────────────────
    in property <image> camera-image;
    in-out property <bool>  live-snap: false;
    in-out property <float> camera-lo: 0.0;
    in-out property <float> camera-hi: 255.0;
    callback snap-requested();
    callback live-toggled(bool);
    callback camera-panned(float, float);
    callback camera-scrolled(float);
    callback camera-settings-changed();

    // ── TabCamProp (type_id 3) ────────────────────────────────────────────────
    in property <[DevicePropEntry]> device-props;

    // ── TabProject (type_id 5) ────────────────────────────────────────────────
    in-out property <int> selected-project-id: -1;
    callback close-project();
    callback project-tree-selected(int);

    // ── TabFileBrowser (type_id 6) ────────────────────────────────────────────
    in property <[FileEntry]> file-list;
    in-out property <string> current-path: ".";
    callback navigate-to(string);
    callback open-file(string);

    // ── Private: tab context menu ─────────────────────────────────────────────
    private property <bool>   tab-menu-open: false;
    private property <int>    tab-menu-idx: 0;
    private property <length> tab-menu-x: 0;

    // ── Private: Tab3d drag ───────────────────────────────────────────────────
    private property <float> v3d-drag-x;
    private property <float> v3d-drag-y;

    // ── Private: Tab2d drag / dropdown ───────────────────────────────────────
    private property <float>  v2d-drag-x;
    private property <float>  v2d-drag-y;
    private property <bool>   v2d-dd-open: false;
    private property <int>    v2d-dd-row: -1;
    private property <string> v2d-dd-label: "";

    // ── Private: Camera drag ──────────────────────────────────────────────────
    private property <float> cam-drag-x;
    private property <float> cam-drag-y;

    // ── Private: CamProp column resize ───────────────────────────────────────
    private property <length> dp-col1-w: 100px;
    private property <length> dp-col3-w: 120px;
    private property <length> dp-hdrag1: 0;
    private property <length> dp-hdrag3: 0;

    // ── Private: FileBrowser ─────────────────────────────────────────────────
    private property <length> fb-size-w: 72px;
    private property <length> fb-drag: 0;
    private property <int>    fb-sel-row: -1;
    private property <bool>   fb-sel-dir: false;

    // ── Private: Project tree ─────────────────────────────────────────────────
    private property <int>    proj-sel-row: -1;

    // ─────────────────────────────────────────────────────────────────────────

    VerticalLayout {
        width: 100%; height: 100%;

        // ── Dynamic tab bar ───────────────────────────────────────────────────
        Rectangle {
            height: 28px;
            background: #222222;
            HorizontalLayout {
                spacing: 0px;
                alignment: start;

                for tab[i] in root.tabs: Rectangle {
                    width: 94px;
                    height: 28px;
                    background: root.active-tab == i ? #3A3A3A : #222222;
                    tab-btn := TouchArea { clicked => { root.active-tab = i; } }
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 2px;
                        spacing: 2px;
                        Text {
                            text: tab.label;
                            color: white;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Rectangle {
                            width: 16px;
                            height: 16px;
                            border-radius: 3px;
                            background: menu-btn.has-hover ? #555555 : transparent;
                            menu-btn := TouchArea {
                                clicked => {
                                    root.active-tab = i;
                                    if (root.tab-menu-open && root.tab-menu-idx == i) {
                                        root.tab-menu-open = false;
                                    } else {
                                        root.tab-menu-idx = i;
                                        root.tab-menu-x = i * 94px;
                                        root.tab-menu-open = true;
                                    }
                                }
                            }
                            Text {
                                text: "⋮";
                                color: #AAAAAA;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // ── Content area ──────────────────────────────────────────────────────
        Rectangle {
            vertical-stretch: 1;
            clip: true;

            // ── 3D View (type_id 0) ───────────────────────────────────────────
            if root.active-tab-type == 0: Rectangle {
                width: 100%; height: 100%;
                Image {
                    source: root.teapot-image;
                    width: 100%; height: 100%;
                    image-fit: fill;
                }
                v3d-ta := TouchArea {
                    mouse-cursor: crosshair;
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            root.v3d-drag-x = self.mouse-x / 1px;
                            root.v3d-drag-y = self.mouse-y / 1px;
                        }
                    }
                    moved => {
                        if (self.pressed) {
                            root.viewer3d-panned(
                                self.mouse-x / 1px - root.v3d-drag-x,
                                self.mouse-y / 1px - root.v3d-drag-y
                            );
                            root.v3d-drag-x = self.mouse-x / 1px;
                            root.v3d-drag-y = self.mouse-y / 1px;
                        }
                    }
                    scroll-event(e) => {
                        root.viewer3d-scrolled(e.delta-y / 1px);
                        return EventResult.accept;
                    }
                }
            }

            // ── 2D Viewer (type_id 1) ─────────────────────────────────────────
            if root.active-tab-type == 1: VerticalLayout {
                width: 100%; height: 100%;

                HorizontalLayout {
                    vertical-stretch: 1;

                    Rectangle {
                        horizontal-stretch: 1;
                        background: #111111;
                        if root.viewer2d-image-loaded: Image {
                            source: root.viewer2d-image;
                            image-fit: fill;
                            width: 100%; height: 100%;
                        }
                        if !root.viewer2d-image-loaded: Text {
                            text: "No image selected";
                            color: #555555; font-size: 14px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        v2d-ta := TouchArea {
                            mouse-cursor: crosshair;
                            pointer-event(e) => {
                                if (e.kind == PointerEventKind.down) {
                                    root.v2d-drag-x = self.mouse-x / 1px;
                                    root.v2d-drag-y = self.mouse-y / 1px;
                                }
                            }
                            moved => {
                                if (self.pressed) {
                                    root.viewer2d-panned(
                                        self.mouse-x / 1px - root.v2d-drag-x,
                                        self.mouse-y / 1px - root.v2d-drag-y
                                    );
                                    root.v2d-drag-x = self.mouse-x / 1px;
                                    root.v2d-drag-y = self.mouse-y / 1px;
                                }
                            }
                            scroll-event(e) => {
                                root.viewer2d-scrolled(e.delta-y / 1px);
                                return EventResult.accept;
                            }
                        }
                    }

                    Rectangle {
                        width: 20px;
                        background: #111111;
                        Slider {
                            width: 20px; height: parent.height;
                            orientation: vertical;
                            minimum: 0; maximum: root.viewer2d-z-max;
                            value <=> root.viewer2d-z;
                            enabled: root.viewer2d-z-max > 0;
                            changed(v) => { root.viewer2d-z-changed(v); }
                        }
                    }
                }

                Rectangle {
                    height: 28px;
                    background: #1A1A1A;
                    HorizontalLayout {
                        padding-left: 6px; padding-right: 6px;
                        padding-top: 4px;  padding-bottom: 4px;
                        RangeSlider {
                            horizontal-stretch: 1;
                            minimum: 0.0; maximum: 255.0;
                            lo <=> root.viewer2d-lo;
                            hi <=> root.viewer2d-hi;
                            changed(l, h) => { root.viewer2d-settings-changed(); }
                        }
                    }
                }

                if root.v2d-dd-open: Rectangle {
                    height: min(200px, v2d-dd-entries.preferred-height);
                    background: #1E1E1E;
                    border-width: 1px;
                    border-color: #444444;
                    clip: true;

                    v2d-flick := Flickable {
                        width: parent.width; height: parent.height;
                        viewport-height: v2d-dd-entries.preferred-height;

                        v2d-dd-entries := VerticalLayout {
                            for entry[i] in root.project-tree: Rectangle {
                                height: 22px;
                                background: v2d-row-ta.has-hover ? #2A3A4A
                                          : root.v2d-dd-row == i ? #1E3A5F : #1E1E1E;
                                v2d-row-ta := TouchArea {
                                    clicked => {
                                        root.v2d-dd-row = i;
                                        root.v2d-dd-label = entry.label;
                                        root.v2d-dd-open = false;
                                        root.viewer2d-object-selected(entry.project-id, entry.object-id);
                                    }
                                }
                                HorizontalLayout {
                                    padding-left: 8px + entry.indent * 16px;
                                    padding-right: 4px;
                                    Text {
                                        text: entry.label;
                                        color: entry.indent == 0 ? #9ABFDD : #CCCCCC;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 32px;
                    background: #1A1A1A;
                    HorizontalLayout {
                        padding: 4px;
                        Rectangle {
                            horizontal-stretch: 1; height: 24px;
                            background: v2d-dd-btn.has-hover ? #3A3A3A : #2A2A2A;
                            border-radius: 3px;
                            v2d-dd-btn := TouchArea {
                                clicked => { root.v2d-dd-open = !root.v2d-dd-open; }
                            }
                            HorizontalLayout {
                                padding-left: 8px; padding-right: 8px;
                                Text {
                                    text: root.v2d-dd-label == "" ? "Select object..." : root.v2d-dd-label;
                                    color: root.v2d-dd-label == "" ? #666666 : #CCCCCC;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                Text { text: "▼"; color: #888888; font-size: 10px; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }

            // ── Camera (type_id 2) ────────────────────────────────────────────
            if root.active-tab-type == 2: VerticalLayout {
                width: 100%; height: 100%;

                Rectangle {
                    vertical-stretch: 1;
                    Image {
                        source: root.camera-image;
                        image-fit: contain;
                        width: 100%; height: 100%;
                    }
                    cam-ta := TouchArea {
                        mouse-cursor: crosshair;
                        pointer-event(e) => {
                            if (e.kind == PointerEventKind.down) {
                                root.cam-drag-x = self.mouse-x / 1px;
                                root.cam-drag-y = self.mouse-y / 1px;
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                root.camera-panned(
                                    self.mouse-x / 1px - root.cam-drag-x,
                                    self.mouse-y / 1px - root.cam-drag-y
                                );
                                root.cam-drag-x = self.mouse-x / 1px;
                                root.cam-drag-y = self.mouse-y / 1px;
                            }
                        }
                        scroll-event(e) => {
                            root.camera-scrolled(e.delta-y / 1px);
                            return EventResult.accept;
                        }
                    }
                }

                Rectangle {
                    height: 32px;
                    background: #1A1A1A;
                    HorizontalLayout {
                        padding: 4px; spacing: 6px; alignment: start;
                        Rectangle {
                            width: 60px; height: 24px;
                            background: snap-btn.has-hover ? #3D3D3D : #2A2A2A;
                            border-radius: 3px;
                            snap-btn := TouchArea { clicked => { root.snap-requested(); } }
                            Text { text: "Snap"; color: white; font-size: 12px;
                                   horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Rectangle {
                            width: 60px; height: 24px;
                            background: live-btn.has-hover ? #3D3D3D : #2A2A2A;
                            border-radius: 3px;
                            border-width: root.live-snap ? 1px : 0px;
                            border-color: #6699CC;
                            live-btn := TouchArea {
                                clicked => {
                                    root.live-snap = !root.live-snap;
                                    root.live-toggled(root.live-snap);
                                }
                            }
                            Text { text: "Live"; font-size: 12px;
                                   color: root.live-snap ? #9ABFDD : white;
                                   horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                Rectangle {
                    height: 28px;
                    background: #1A1A1A;
                    HorizontalLayout {
                        padding-left: 6px; padding-right: 6px;
                        padding-top: 4px;  padding-bottom: 4px;
                        RangeSlider {
                            horizontal-stretch: 1;
                            minimum: 0.0; maximum: 255.0;
                            lo <=> root.camera-lo;
                            hi <=> root.camera-hi;
                            changed(l, h) => { root.camera-settings-changed(); }
                        }
                    }
                }
            }

            // ── CamProp (type_id 3) ───────────────────────────────────────────
            if root.active-tab-type == 3: VerticalLayout {
                width: 100%; height: 100%;

                Rectangle {
                    height: 20px;
                    background: #000000;
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px;
                        Text { text: "Device";   color: #888888; font-size: 11px; vertical-alignment: center; width: root.dp-col1-w; overflow: elide; }
                        Rectangle {
                            width: 5px; height: parent.height;
                            background: dph1.pressed ? #666666 : (dph1.has-hover ? #444444 : transparent);
                            dph1 := TouchArea {
                                mouse-cursor: col-resize;
                                pointer-event(e) => { if (e.kind == PointerEventKind.down) { root.dp-hdrag1 = self.mouse-x; } }
                                moved => { root.dp-col1-w = max(40px, root.dp-col1-w + self.mouse-x - root.dp-hdrag1); }
                            }
                        }
                        Text { text: "Property"; color: #888888; font-size: 11px; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                        Rectangle {
                            width: 5px; height: parent.height;
                            background: dph3.pressed ? #666666 : (dph3.has-hover ? #444444 : transparent);
                            dph3 := TouchArea {
                                mouse-cursor: col-resize;
                                pointer-event(e) => { if (e.kind == PointerEventKind.down) { root.dp-hdrag3 = self.mouse-x; } }
                                moved => { root.dp-col3-w = max(40px, root.dp-col3-w - (self.mouse-x - root.dp-hdrag3)); }
                            }
                        }
                        Text { text: "Value";    color: #888888; font-size: 11px; vertical-alignment: center; width: root.dp-col3-w; overflow: elide; }
                    }
                }
                Rectangle { height: 1px; background: #2A2A2A; }

                Rectangle {
                    vertical-stretch: 1;
                    background: #000000;
                    clip: true;

                    prop-flick := Flickable {
                        width: parent.width - 8px;
                        height: parent.height;
                        viewport-height: prop-entries.preferred-height;

                        prop-entries := VerticalLayout {
                            for entry in root.device-props: Rectangle {
                                height: 22px;
                                background: prop-row.has-hover ? #1E1E1E : #000000;
                                prop-row := TouchArea {}
                                HorizontalLayout {
                                    padding-left: 4px; padding-right: 4px; spacing: 0px;
                                    Text { text: entry.device;   color: #6699CC; font-size: 12px; vertical-alignment: center; width: root.dp-col1-w; overflow: elide; }
                                    Rectangle { width: 5px; }
                                    Text { text: entry.property; color: #CCCCCC; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                                    Rectangle { width: 5px; }
                                    Text { text: entry.value;    color: #AAAAAA; font-size: 12px; vertical-alignment: center; width: root.dp-col3-w; overflow: elide; }
                                }
                            }
                        }
                    }

                    Rectangle {
                        x: parent.width - 6px; width: 6px; height: parent.height;
                        background: #111111;
                        Rectangle {
                            visible: prop-flick.viewport-height > prop-flick.height;
                            width: 4px; x: 1px;
                            y: (-prop-flick.viewport-y / prop-flick.viewport-height) * parent.height;
                            height: max(20px, (prop-flick.height / prop-flick.viewport-height) * parent.height);
                            background: #555555; border-radius: 2px;
                        }
                    }
                }
            }

            // ── ParticleTracking (type_id 4) ──────────────────────────────────
            if root.active-tab-type == 4: VerticalLayout {
                width: 100%; height: 100%;
                alignment: center;
                Text { text: "Particle tracking"; color: #555555; font-size: 13px; horizontal-alignment: center; }
            }

            // ── Project (type_id 5) ───────────────────────────────────────────
            if root.active-tab-type == 5: VerticalLayout {
                width: 100%; height: 100%;

                Rectangle {
                    vertical-stretch: 1;
                    background: #000000;
                    clip: true;

                    proj-flick := Flickable {
                        width: parent.width - 8px;
                        height: parent.height;
                        viewport-height: proj-entries.preferred-height;

                        proj-entries := VerticalLayout {
                            for entry[i] in root.project-tree: Rectangle {
                                height: 22px;
                                background: root.proj-sel-row == i ? #1E3A5F : #000000;
                                row-ta := TouchArea {
                                    clicked => {
                                        root.proj-sel-row = i;
                                        root.project-tree-selected(entry.object-id);
                                        if (entry.indent == 0) {
                                            root.selected-project-id = entry.object-id;
                                        }
                                    }
                                }
                                HorizontalLayout {
                                    padding-left: 8px + entry.indent * 16px; padding-right: 4px;
                                    Text {
                                        text: entry.label;
                                        color: entry.indent == 0 ? #9ABFDD : #CCCCCC;
                                        font-size: 13px; vertical-alignment: center; overflow: elide;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        x: parent.width - 6px; width: 6px; height: parent.height;
                        background: #111111;
                        Rectangle {
                            visible: proj-flick.viewport-height > proj-flick.height;
                            width: 4px; x: 1px;
                            y: (-proj-flick.viewport-y / proj-flick.viewport-height) * parent.height;
                            height: max(20px, (proj-flick.height / proj-flick.viewport-height) * parent.height);
                            background: #555555; border-radius: 2px;
                        }
                    }
                }

                Rectangle {
                    height: 32px;
                    background: #1A1A1A;
                    HorizontalLayout {
                        padding: 4px; spacing: 6px; alignment: start;
                        Rectangle {
                            width: 60px; height: 24px;
                            background: close-proj-btn.has-hover ? #3D3D3D : #2A2A2A;
                            border-radius: 3px;
                            close-proj-btn := TouchArea { clicked => { root.close-project(); } }
                            Text { text: "Close"; color: white; font-size: 12px;
                                   horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
            }

            // ── FileBrowser (type_id 6) ───────────────────────────────────────
            if root.active-tab-type == 6: VerticalLayout {
                width: 100%; height: 100%;

                Rectangle {
                    height: 26px;
                    background: #1E1E1E;
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 4px;
                        Rectangle {
                            width: 28px;
                            background: up-btn.has-hover ? #3A3A3A : #2A2A2A;
                            border-radius: 3px;
                            up-btn := TouchArea { clicked => { root.navigate-to(".."); } }
                            Text { text: "↑"; color: #AAAAAA;
                                   horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Text {
                            text: root.current-path; color: #AAAAAA; font-size: 12px;
                            vertical-alignment: center; overflow: elide; horizontal-stretch: 1;
                        }
                    }
                }
                Rectangle { height: 1px; background: #333333; }

                Rectangle {
                    height: 20px;
                    background: #000000;
                    HorizontalLayout {
                        padding-left: 24px; padding-right: 4px;
                        Text { text: "Name"; color: #888888; font-size: 11px;
                               vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                        Rectangle {
                            width: 5px; height: parent.height;
                            background: fh.pressed ? #666666 : (fh.has-hover ? #444444 : transparent);
                            fh := TouchArea {
                                mouse-cursor: col-resize;
                                pointer-event(e) => { if (e.kind == PointerEventKind.down) { root.fb-drag = self.mouse-x; } }
                                moved => { root.fb-size-w = max(40px, root.fb-size-w - (self.mouse-x - root.fb-drag)); }
                            }
                        }
                        Text { text: "Size"; color: #888888; font-size: 11px;
                               vertical-alignment: center; width: root.fb-size-w; horizontal-alignment: right; }
                    }
                }
                Rectangle { height: 1px; background: #2A2A2A; }

                Rectangle {
                    vertical-stretch: 1;
                    background: #000000;
                    clip: true;

                    file-flick := Flickable {
                        width: parent.width - 8px;
                        height: parent.height;
                        viewport-height: file-entries.preferred-height;

                        file-entries := VerticalLayout {
                            for entry[i] in root.file-list: Rectangle {
                                height: 22px;
                                background: root.fb-sel-row == i ? #1E3A5F
                                          : entry-area.has-hover ? #1E1E1E : #000000;
                                entry-area := TouchArea {
                                    clicked => {
                                        root.fb-sel-row = i;
                                        root.fb-sel-dir = entry.is-dir;
                                        if (entry.is-dir) {
                                            root.fb-sel-row = -1;
                                            root.fb-sel-dir = false;
                                            root.navigate-to(entry.name);
                                        }
                                    }
                                    double-clicked => {
                                        if (!entry.is-dir) { root.open-file(entry.name); }
                                    }
                                }
                                HorizontalLayout {
                                    padding-left: 8px; padding-right: 4px; spacing: 4px;
                                    Text { text: entry.is-dir ? "▶" : " "; color: #6699CC;
                                           font-size: 11px; vertical-alignment: center; width: 12px; }
                                    Text { text: entry.name;
                                           color: entry.is-dir ? #9ABFDD : #CCCCCC;
                                           font-size: 13px; vertical-alignment: center;
                                           horizontal-stretch: 1; overflow: elide; }
                                    Text { text: entry.size; color: #777777; font-size: 12px;
                                           vertical-alignment: center; width: root.fb-size-w;
                                           horizontal-alignment: right; }
                                }
                            }
                        }
                    }

                    Rectangle {
                        x: parent.width - 6px; width: 6px; height: parent.height;
                        background: #111111;
                        Rectangle {
                            visible: file-flick.viewport-height > file-flick.height;
                            width: 4px; x: 1px;
                            y: (-file-flick.viewport-y / file-flick.viewport-height) * parent.height;
                            height: max(20px, (file-flick.height / file-flick.viewport-height) * parent.height);
                            background: #555555; border-radius: 2px;
                        }
                    }
                }

                Rectangle {
                    height: 32px;
                    background: #1A1A1A;
                    HorizontalLayout {
                        padding: 4px; spacing: 6px; alignment: start;
                        Rectangle {
                            width: 60px; height: 24px;
                            opacity: root.fb-sel-row >= 0 && !root.fb-sel-dir ? 1.0 : 0.4;
                            background: open-btn.has-hover && root.fb-sel-row >= 0 && !root.fb-sel-dir ? #3D3D3D : #2A2A2A;
                            border-radius: 3px;
                            open-btn := TouchArea {
                                clicked => {
                                    if (root.fb-sel-row >= 0 && !root.fb-sel-dir) {
                                        root.open-file(root.file-list[root.fb-sel-row].name);
                                    }
                                }
                            }
                            Text { text: "Open"; color: white; font-size: 12px;
                                   horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
            }

            // ── Plots placeholder (type_id 7) ─────────────────────────────────
            if root.active-tab-type == 7: Rectangle {
                width: 100%; height: 100%;
                background: #111111;
            }

            // ── Help placeholder (type_id 8) ──────────────────────────────────
            if root.active-tab-type == 8: Rectangle {
                width: 100%; height: 100%;
                background: #111111;
            }
        }
    }

    // ── Dismiss overlay (behind tab menu) ─────────────────────────────────────
    if root.tab-menu-open: Rectangle {
        z: 1;
        width: 100%; height: 100%;
        background: transparent;
        TouchArea {
            width: 100%; height: 100%;
            clicked => { root.tab-menu-open = false; }
        }
    }

    // ── Tab context menu ──────────────────────────────────────────────────────
    if root.tab-menu-open: Rectangle {
        z: 2;
        x: root.tab-menu-x;
        y: 28px;
        width: 148px;
        height: menu-layout.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;
        drop-shadow-color: #00000060;
        drop-shadow-blur: 6px;

        TouchArea { width: 100%; height: 100%; }  // prevent click-through

        menu-layout := VerticalLayout {
            if root.current-area != 0: Rectangle {
                height: 28px;
                background: ml-ta.has-hover ? #3D3D3D : transparent;
                ml-ta := TouchArea {
                    clicked => { root.tab-menu-open = false; root.move-tab(root.tab-menu-idx, 0); }
                }
                Text { text: "Move left"; color: white; font-size: 12px;
                       x: 10px; height: parent.height; vertical-alignment: center; }
            }
            if root.current-area != 1: Rectangle {
                height: 28px;
                background: mtr-ta.has-hover ? #3D3D3D : transparent;
                mtr-ta := TouchArea {
                    clicked => { root.tab-menu-open = false; root.move-tab(root.tab-menu-idx, 1); }
                }
                Text { text: "Move top right"; color: white; font-size: 12px;
                       x: 10px; height: parent.height; vertical-alignment: center; }
            }
            if root.current-area != 2: Rectangle {
                height: 28px;
                background: mbr-ta.has-hover ? #3D3D3D : transparent;
                mbr-ta := TouchArea {
                    clicked => { root.tab-menu-open = false; root.move-tab(root.tab-menu-idx, 2); }
                }
                Text { text: "Move bottom right"; color: white; font-size: 12px;
                       x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle { height: 1px; background: #444444; }
            Rectangle {
                height: 28px;
                background: cl-ta.has-hover ? #3D3D3D : transparent;
                cl-ta := TouchArea {
                    clicked => { root.tab-menu-open = false; root.close-tab(root.tab-menu-idx); }
                }
                Text { text: "Close"; color: #FF8888; font-size: 12px;
                       x: 10px; height: parent.height; vertical-alignment: center; }
            }
        }
    }
}
