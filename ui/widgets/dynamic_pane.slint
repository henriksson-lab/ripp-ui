import { LeftTabEntry, DevicePropEntry, ProjectTreeEntry, FileEntry } from "../types.slint";
import { PaneViewer3d }         from "../panels/pane_viewer3d.slint";
import { PaneViewer2d }         from "../panels/pane_viewer2d.slint";
import { PaneCamera }           from "../panels/pane_camera.slint";
import { PaneCamProp }          from "../panels/pane_cam_prop.slint";
import { PaneParticleTracking } from "../panels/pane_particle_tracking.slint";
import { PaneProject }          from "../panels/pane_project.slint";
import { PaneFileBrowser }      from "../panels/pane_file_browser.slint";
import { PanePlots }            from "../panels/pane_plots.slint";
import { PaneHelp }             from "../panels/pane_help.slint";
import { PanePanScan }          from "../panels/pane_pan_scan.slint";

export component DynamicPane inherits Rectangle {
    // ── Tab management ────────────────────────────────────────────────────────
    in-out property <[LeftTabEntry]> tabs;
    in-out property <int> active-tab: 0;
    out property <int> active-tab-type:
        (root.active-tab < root.tabs.length) ? root.tabs[root.active-tab].tab-type : -1;
    in property <int> current-area: 0;  // 0=Left 1=RightTop 2=RightBottom
    callback close-tab(int);
    callback move-tab(int, int);    // (tab_idx, target_area)
    callback add-pane(int, int);    // (area, type_id)
    callback tab-action(int, int);  // (tab_idx, action_id)

    // ── Tab3d (type_id 0) ─────────────────────────────────────────────────────
    in property <image> teapot-image;
    callback viewer3d-panned(float, float);
    callback viewer3d-scrolled(float);
    callback viewer3d-resized(float, float);

    // ── Tab2d (type_id 1) ─────────────────────────────────────────────────────
    in property <image> viewer2d-image;
    in-out property <bool>  viewer2d-image-loaded: false;
    in-out property <float> viewer2d-lo: 0.0;
    in-out property <float> viewer2d-hi: 255.0;
    in-out property <float> viewer2d-z: 0;
    in-out property <float> viewer2d-z-max: 0;
    in property <[ProjectTreeEntry]> project-tree;
    callback viewer2d-panned(float, float);
    callback viewer2d-scrolled(float);
    callback viewer2d-settings-changed();
    callback viewer2d-z-changed(float);
    callback viewer2d-object-selected(int, int);
    callback viewer2d-resized(float, float);

    // ── TabCamera (type_id 2) ─────────────────────────────────────────────────
    in property <image> camera-image;
    in-out property <bool>  live-snap: false;
    in-out property <float> camera-lo: 0.0;
    in-out property <float> camera-hi: 255.0;
    callback snap-requested();
    callback live-toggled(bool);
    callback camera-panned(float, float);
    callback camera-scrolled(float);
    callback camera-settings-changed();

    // ── TabCamProp (type_id 3) ────────────────────────────────────────────────
    in property <[DevicePropEntry]> device-props;

    // ── TabProject (type_id 5) ────────────────────────────────────────────────
    in-out property <int> selected-project-id: -1;
    callback close-project();
    callback project-tree-selected(int);

    // ── TabPanScan (type_id 9) ────────────────────────────────────────────────
    in property <image> panscan-image;
    in-out property <float>  panscan-lo: 0.0;
    in-out property <float>  panscan-hi: 255.0;
    in-out property <string> panscan-min-x: "";
    in-out property <string> panscan-max-x: "";
    in-out property <string> panscan-min-y: "";
    in-out property <string> panscan-max-y: "";
    callback panscan-panned(float, float);
    callback panscan-scrolled(float);
    callback panscan-settings-changed();
    callback panscan-set-corner();
    callback panscan-reset();
    callback panscan-record();
    callback panscan-field-edited(int, string);

    // ── TabFileBrowser (type_id 6) ────────────────────────────────────────────
    in property <[FileEntry]> file-list;
    in-out property <string> current-path: ".";
    callback navigate-to(string);
    callback open-file(string);

    // ── Private: tab context menu ─────────────────────────────────────────────
    private property <bool>   tab-menu-open: false;
    private property <int>    tab-menu-idx: 0;
    private property <length> tab-menu-x: 0;
    private property <bool>   add-menu-open: false;

    // ─────────────────────────────────────────────────────────────────────────

    VerticalLayout {
        width: 100%; height: 100%;

        // ── Dynamic tab bar ───────────────────────────────────────────────────
        Rectangle {
            height: 28px;
            background: #222222;
            HorizontalLayout {
                spacing: 0px;
                alignment: start;

                for tab[i] in root.tabs: Rectangle {
                    width: 94px;
                    height: 28px;
                    background: root.active-tab == i ? #3A3A3A : #222222;
                    tab-btn := TouchArea { clicked => { root.active-tab = i; } }
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 2px;
                        spacing: 2px;
                        Text {
                            text: tab.label;
                            color: white;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Rectangle {
                            width: 16px;
                            background: menu-btn.has-hover ? #555555 : transparent;
                            menu-btn := TouchArea {
                                clicked => {
                                    root.active-tab = i;
                                    if (root.tab-menu-open && root.tab-menu-idx == i) {
                                        root.tab-menu-open = false;
                                    } else {
                                        root.tab-menu-idx = i;
                                        root.tab-menu-x = i * 94px;
                                        root.tab-menu-open = true;
                                    }
                                }
                            }
                            Text {
                                text: "▼";
                                color: #AAAAAA;
                                font-size: 10px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── Add-pane button ───────────────────────────────────────────
                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: add-btn.has-hover ? #3A3A3A : transparent;
                    add-btn := TouchArea {
                        clicked => {
                            root.tab-menu-open = false;
                            root.add-menu-open = !root.add-menu-open;
                        }
                    }
                    Text {
                        text: "+";
                        color: #AAAAAA;
                        font-size: 18px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── Content area ──────────────────────────────────────────────────────
        Rectangle {
            vertical-stretch: 1;
            clip: true;

            if root.active-tab-type == 0: PaneViewer3d {
                width: 100%; height: 100%;
                teapot-image: root.teapot-image;
                viewer3d-panned(dx, dy) => { root.viewer3d-panned(dx, dy); }
                viewer3d-scrolled(d)    => { root.viewer3d-scrolled(d); }
                viewer3d-resized(w, h)  => { root.viewer3d-resized(w, h); }
            }

            if root.active-tab-type == 1: PaneViewer2d {
                width: 100%; height: 100%;
                viewer2d-image        <=> root.viewer2d-image;
                viewer2d-image-loaded <=> root.viewer2d-image-loaded;
                viewer2d-lo           <=> root.viewer2d-lo;
                viewer2d-hi           <=> root.viewer2d-hi;
                viewer2d-z            <=> root.viewer2d-z;
                viewer2d-z-max        <=> root.viewer2d-z-max;
                project-tree:             root.project-tree;
                viewer2d-panned(dx, dy)        => { root.viewer2d-panned(dx, dy); }
                viewer2d-scrolled(d)           => { root.viewer2d-scrolled(d); }
                viewer2d-settings-changed()    => { root.viewer2d-settings-changed(); }
                viewer2d-z-changed(v)          => { root.viewer2d-z-changed(v); }
                viewer2d-object-selected(p, o) => { root.viewer2d-object-selected(p, o); }
                viewer2d-resized(w, h)         => { root.viewer2d-resized(w, h); }
            }

            if root.active-tab-type == 2: PaneCamera {
                width: 100%; height: 100%;
                camera-image <=> root.camera-image;
                live-snap    <=> root.live-snap;
                camera-lo    <=> root.camera-lo;
                camera-hi    <=> root.camera-hi;
                snap-requested()            => { root.snap-requested(); }
                live-toggled(v)             => { root.live-toggled(v); }
                camera-panned(dx, dy)       => { root.camera-panned(dx, dy); }
                camera-scrolled(d)          => { root.camera-scrolled(d); }
                camera-settings-changed()   => { root.camera-settings-changed(); }
            }

            if root.active-tab-type == 3: PaneCamProp {
                width: 100%; height: 100%;
                device-props: root.device-props;
            }

            if root.active-tab-type == 4: PaneParticleTracking {
                width: 100%; height: 100%;
            }

            if root.active-tab-type == 5: PaneProject {
                width: 100%; height: 100%;
                project-tree:          root.project-tree;
                selected-project-id <=> root.selected-project-id;
                close-project()              => { root.close-project(); }
                project-tree-selected(id)    => { root.project-tree-selected(id); }
            }

            if root.active-tab-type == 6: PaneFileBrowser {
                width: 100%; height: 100%;
                file-list:       root.file-list;
                current-path  <=> root.current-path;
                navigate-to(p)   => { root.navigate-to(p); }
                open-file(f)     => { root.open-file(f); }
            }

            if root.active-tab-type == 7: PanePlots {
                width: 100%; height: 100%;
            }

            if root.active-tab-type == 8: PaneHelp {
                width: 100%; height: 100%;
            }

            if root.active-tab-type == 9: PanePanScan {
                width: 100%; height: 100%;
                panscan-image <=> root.panscan-image;
                panscan-lo    <=> root.panscan-lo;
                panscan-hi    <=> root.panscan-hi;
                panscan-min-x <=> root.panscan-min-x;
                panscan-max-x <=> root.panscan-max-x;
                panscan-min-y <=> root.panscan-min-y;
                panscan-max-y <=> root.panscan-max-y;
                panscan-panned(dx, dy)       => { root.panscan-panned(dx, dy); }
                panscan-scrolled(d)          => { root.panscan-scrolled(d); }
                panscan-settings-changed()   => { root.panscan-settings-changed(); }
                panscan-set-corner()         => { root.panscan-set-corner(); }
                panscan-reset()              => { root.panscan-reset(); }
                panscan-record()             => { root.panscan-record(); }
                panscan-field-edited(f, t)   => { root.panscan-field-edited(f, t); }
            }
        }
    }

    // ── Dismiss overlay (behind both menus) ──────────────────────────────────
    if root.tab-menu-open || root.add-menu-open: Rectangle {
        z: 1;
        width: 100%; height: 100%;
        background: transparent;
        TouchArea {
            width: 100%; height: 100%;
            clicked => { root.tab-menu-open = false; root.add-menu-open = false; }
        }
    }

    // ── Add-pane dropdown ─────────────────────────────────────────────────────
    if root.add-menu-open: Rectangle {
        z: 2;
        x: root.tabs.length * 94px;
        y: 28px;
        width: 148px;
        height: add-menu-layout.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;
        drop-shadow-color: #00000060;
        drop-shadow-blur: 6px;

        TouchArea { width: 100%; height: 100%; }  // prevent click-through

        add-menu-layout := VerticalLayout {
            Rectangle {
                height: 28px;
                background: ap0.has-hover ? #3D3D3D : transparent;
                ap0 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 0); } }
                Text { text: "3D View";           color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle {
                height: 28px;
                background: ap1.has-hover ? #3D3D3D : transparent;
                ap1 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 1); } }
                Text { text: "2D Viewer";          color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle {
                height: 28px;
                background: ap2.has-hover ? #3D3D3D : transparent;
                ap2 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 2); } }
                Text { text: "Camera";             color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle { height: 1px; background: #444444; }
            Rectangle {
                height: 28px;
                background: ap3.has-hover ? #3D3D3D : transparent;
                ap3 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 3); } }
                Text { text: "Cam Properties";    color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle {
                height: 28px;
                background: ap4.has-hover ? #3D3D3D : transparent;
                ap4 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 4); } }
                Text { text: "Particle Tracking"; color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle { height: 1px; background: #444444; }
            Rectangle {
                height: 28px;
                background: ap5.has-hover ? #3D3D3D : transparent;
                ap5 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 5); } }
                Text { text: "Project";            color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle {
                height: 28px;
                background: ap6.has-hover ? #3D3D3D : transparent;
                ap6 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 6); } }
                Text { text: "Files";              color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle {
                height: 28px;
                background: ap7.has-hover ? #3D3D3D : transparent;
                ap7 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 7); } }
                Text { text: "Plots";              color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle {
                height: 28px;
                background: ap8.has-hover ? #3D3D3D : transparent;
                ap8 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 8); } }
                Text { text: "Help";               color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle {
                height: 28px;
                background: ap9.has-hover ? #3D3D3D : transparent;
                ap9 := TouchArea { clicked => { root.add-menu-open = false; root.add-pane(root.current-area, 9); } }
                Text { text: "Panorama scan";      color: white; font-size: 12px; x: 10px; height: parent.height; vertical-alignment: center; }
            }
        }
    }

    // ── Tab context menu ──────────────────────────────────────────────────────
    if root.tab-menu-open: Rectangle {
        z: 2;
        x: root.tab-menu-x;
        y: 28px;
        width: 148px;
        height: menu-layout.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;
        drop-shadow-color: #00000060;
        drop-shadow-blur: 6px;

        TouchArea { width: 100%; height: 100%; }  // prevent click-through

        menu-layout := VerticalLayout {
            if root.current-area != 0: Rectangle {
                height: 28px;
                background: ml-ta.has-hover ? #3D3D3D : transparent;
                ml-ta := TouchArea {
                    clicked => { root.tab-menu-open = false; root.move-tab(root.tab-menu-idx, 0); }
                }
                Text { text: "Move left"; color: white; font-size: 12px;
                       x: 10px; height: parent.height; vertical-alignment: center; }
            }
            if root.current-area != 1: Rectangle {
                height: 28px;
                background: mtr-ta.has-hover ? #3D3D3D : transparent;
                mtr-ta := TouchArea {
                    clicked => { root.tab-menu-open = false; root.move-tab(root.tab-menu-idx, 1); }
                }
                Text { text: "Move top right"; color: white; font-size: 12px;
                       x: 10px; height: parent.height; vertical-alignment: center; }
            }
            if root.current-area != 2: Rectangle {
                height: 28px;
                background: mbr-ta.has-hover ? #3D3D3D : transparent;
                mbr-ta := TouchArea {
                    clicked => { root.tab-menu-open = false; root.move-tab(root.tab-menu-idx, 2); }
                }
                Text { text: "Move bottom right"; color: white; font-size: 12px;
                       x: 10px; height: parent.height; vertical-alignment: center; }
            }
            if root.tabs[root.tab-menu-idx].menu-actions.length > 0: Rectangle {
                height: 1px; background: #444444;
            }
            for action in root.tabs[root.tab-menu-idx].menu-actions: Rectangle {
                height: 28px;
                background: ca-ta.has-hover ? #3D3D3D : transparent;
                ca-ta := TouchArea {
                    clicked => {
                        root.tab-menu-open = false;
                        root.tab-action(root.tab-menu-idx, action.action-id);
                    }
                }
                Text { text: action.label; color: white; font-size: 12px;
                       x: 10px; height: parent.height; vertical-alignment: center; }
            }
            Rectangle { height: 1px; background: #444444; }
            Rectangle {
                height: 28px;
                background: cl-ta.has-hover ? #3D3D3D : transparent;
                cl-ta := TouchArea {
                    clicked => { root.tab-menu-open = false; root.close-tab(root.tab-menu-idx); }
                }
                Text { text: "Close"; color: #FF8888; font-size: 12px;
                       x: 10px; height: parent.height; vertical-alignment: center; }
            }
        }
    }
}
