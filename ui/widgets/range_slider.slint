export component RangeSlider {
    in-out property <float> minimum: 0.0;
    in-out property <float> maximum: 255.0;
    in-out property <float> lo: 0.0;
    in-out property <float> hi: 255.0;
    callback changed(float, float);

    height: 20px;
    private property <bool> moving-lo: false;

    // Track
    Rectangle {
        y: (parent.height - 4px) / 2;
        height: 4px;
        width: parent.width;
        background: #333333;
        border-radius: 2px;

        Rectangle {
            x: (root.lo - root.minimum) / (root.maximum - root.minimum) * parent.width;
            width: (root.hi - root.lo) / (root.maximum - root.minimum) * parent.width;
            height: 4px;
            background: #6699CC;
            border-radius: 2px;
        }
    }

    // Lo knob
    Rectangle {
        x: (root.lo - root.minimum) / (root.maximum - root.minimum) * (parent.width - self.width);
        y: (parent.height - self.height) / 2;
        width: 12px; height: 12px;
        border-radius: 6px;
        background: #CCCCCC;
    }

    // Hi knob
    Rectangle {
        x: (root.hi - root.minimum) / (root.maximum - root.minimum) * (parent.width - self.width);
        y: (parent.height - self.height) / 2;
        width: 12px; height: 12px;
        border-radius: 6px;
        background: #CCCCCC;
    }

    TouchArea {
        mouse-cursor: ew-resize;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                let mx = self.mouse-x / parent.width;
                let lo-frac = (root.lo - root.minimum) / (root.maximum - root.minimum);
                let hi-frac = (root.hi - root.minimum) / (root.maximum - root.minimum);
                root.moving-lo = abs(mx - lo-frac) <= abs(mx - hi-frac);
            }
        }
        moved => {
            if (self.pressed) {
                let frac = clamp(self.mouse-x / parent.width, 0.0, 1.0);
                let val = root.minimum + frac * (root.maximum - root.minimum);
                if (root.moving-lo) {
                    root.lo = clamp(val, root.minimum, root.hi);
                } else {
                    root.hi = clamp(val, root.lo, root.maximum);
                }
                root.changed(root.lo, root.hi);
            }
        }
    }
}
