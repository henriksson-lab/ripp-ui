import { ListView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "RIPP — Rust Imaging Processing Platform";
    min-width: 640px;
    min-height: 400px;

    // Set by Rust each frame
    in property <image> teapot-image;

    // Internal UI state
    private property <bool> file-menu-open: false;
    private property <bool> help-menu-open: false;
    private property <bool> about-open: false;

    in property <bool> server-mode: false;
    in property <[string]> file-list;

    // Only action that needs Rust
    callback quit();

    // ── Main layout ──────────────────────────────────────────────────────────
    VerticalLayout {
        // Menubar
        Rectangle {
            height: 36px;
            background: #2B2B2B;

            HorizontalLayout {
                padding: 4px;
                spacing: 2px;
                alignment: start;

                Rectangle {
                    width: 60px;
                    height: 28px;
                    background: file-btn.has-hover ? #3D3D3D : transparent;
                    border-radius: 3px;
                    file-btn := TouchArea {
                        clicked => {
                            root.about-open = false;
                            root.help-menu-open = false;
                            root.file-menu-open = !root.file-menu-open;
                        }
                    }
                    Text {
                        text: "File";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 60px;
                    height: 28px;
                    background: help-btn.has-hover ? #3D3D3D : transparent;
                    border-radius: 3px;
                    help-btn := TouchArea {
                        clicked => {
                            root.about-open = false;
                            root.file-menu-open = false;
                            root.help-menu-open = !root.help-menu-open;
                        }
                    }
                    Text {
                        text: "Help";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Content area
        HorizontalLayout {
            vertical-stretch: 1;

            // Left pane: split vertically
            VerticalLayout {
                horizontal-stretch: 1;

                // Top: Hello World
                Rectangle {
                    vertical-stretch: 1;
                    background: #1A1A1A;

                    left-mouse := TouchArea {
                        width: parent.width;
                        height: parent.height;
                    }

                    VerticalLayout {
                        alignment: center;
                        spacing: 12px;

                        Text {
                            text: "Hello World";
                            color: white;
                            font-size: 32px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "x: " + Math.round(left-mouse.mouse-x / 1px) + "  y: " + Math.round(left-mouse.mouse-y / 1px);
                            color: #AAAAAA;
                            font-size: 14px;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Divider
                Rectangle { height: 1px; background: #444444; }

                // Bottom: file list
                Rectangle {
                    vertical-stretch: 1;
                    background: #111111;
                    clip: true;

                    ListView {
                        width: parent.width;
                        height: parent.height;
                        for name in root.file-list: Rectangle {
                            height: 22px;
                            background: transparent;
                            Text {
                                x: 8px;
                                text: name;
                                color: #CCCCCC;
                                font-size: 13px;
                                vertical-alignment: center;
                                height: parent.height;
                            }
                        }
                    }
                }
            }

            // Right pane: teapot
            Image {
                source: root.teapot-image;
                horizontal-stretch: 1;
                image-fit: fill;
            }
        }
    }

    // ── Dismiss overlay (behind dropdowns) ───────────────────────────────────
    if root.file-menu-open || root.help-menu-open: Rectangle {
        z: 1;
        width: root.width;
        height: root.height;
        background: transparent;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.file-menu-open = false;
                root.help-menu-open = false;
            }
        }
    }

    // ── File dropdown ─────────────────────────────────────────────────────────
    if root.file-menu-open: Rectangle {
        z: 2;
        x: 4px;
        y: 36px;
        width: 120px;
        height: file-drop.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;

        file-drop := VerticalLayout {
            Rectangle {
                height: 30px;
                background: new-item.has-hover ? #3D3D3D : transparent;
                new-item := TouchArea {
                    clicked => { root.file-menu-open = false; }
                }
                Text {
                    text: "New";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
            Rectangle {
                height: 30px;
                background: quit-item.has-hover ? #3D3D3D : transparent;
                quit-item := TouchArea {
                    clicked => { root.quit(); }
                }
                Text {
                    text: root.server-mode ? "Shut down server" : "Quit";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
        }
    }

    // ── Help dropdown ─────────────────────────────────────────────────────────
    if root.help-menu-open: Rectangle {
        z: 2;
        x: 66px;
        y: 36px;
        width: 120px;
        height: help-drop.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;

        help-drop := VerticalLayout {
            Rectangle {
                height: 30px;
                background: about-item.has-hover ? #3D3D3D : transparent;
                about-item := TouchArea {
                    clicked => {
                        root.help-menu-open = false;
                        root.about-open = true;
                    }
                }
                Text {
                    text: "About";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
        }
    }

    // ── About backdrop ────────────────────────────────────────────────────────
    if root.about-open: Rectangle {
        z: 10;
        width: root.width;
        height: root.height;
        background: #00000080;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.about-open = false; }
        }
    }

    // ── About dialog ──────────────────────────────────────────────────────────
    if root.about-open: Rectangle {
        z: 11;
        width: 280px;
        height: about-layout.preferred-height + 48px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;
        border-radius: 4px;

        // absorb clicks so backdrop TouchArea doesn't fire
        TouchArea { width: parent.width; height: parent.height; }

        about-layout := VerticalLayout {
            padding: 24px;
            spacing: 8px;

            Text { text: "About"; font-size: 20px; color: white; }
            Text { text: "Work in progress"; color: white; }
            Rectangle { height: 8px; }

            Rectangle {
                height: 32px;
                width: 60px;
                background: ok-btn.has-hover ? #3D3D3D : #444444;
                border-radius: 3px;
                ok-btn := TouchArea {
                    clicked => { root.about-open = false; }
                }
                Text {
                    text: "OK";
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
