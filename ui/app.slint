import { FileEntry, DevicePropEntry, LeftTabEntry, ProjectTreeEntry } from "types.slint";
export { FileEntry, DevicePropEntry, LeftTabEntry, ProjectTreeEntry }

import { LeftPane }                    from "panels/left_pane.slint";
import { RightTopPane, RightBottomPane } from "panels/right_panes.slint";

export component AppWindow inherits Window {
    title: "RIPP — Rust Imaging Processing Platform";
    min-width: 640px;
    min-height: 400px;

    // ── Properties (Rust-visible) ─────────────────────────────────────────────
    in property <image> teapot-image;
    in property <image> camera-image;
    in property <bool>  server-mode: false;
    in-out property <string> error-message: "";
    in property <[FileEntry]> file-list;
    in property <string> current-path: ".";
    in property <[DevicePropEntry]> device-props;
    in property <[ProjectTreeEntry]> project-tree;

    in-out property <int>  selected-project-id: -1;
    in-out property <int>  active-left-tab: 0;
    in-out property <[LeftTabEntry]> left-tabs;
    in-out property <[LeftTabEntry]> right-top-tabs;
    in-out property <int>  active-right-top-tab: 0;
    in-out property <[LeftTabEntry]> right-bottom-tabs;
    in-out property <int>  active-right-bottom-tab: 0;

    in property <image> viewer2d-image;
    in-out property <bool>  viewer2d-image-loaded: false;
    in-out property <float> viewer2d-lo: 0.0;
    in-out property <float> viewer2d-hi: 255.0;
    in-out property <float> viewer2d-z: 0;
    in-out property <float> viewer2d-z-max: 0;

    in-out property <bool>  live-snap: false;
    in-out property <float> camera-lo: 0.0;
    in-out property <float> camera-hi: 255.0;

    in property <image>  panscan-image;
    in-out property <float>  panscan-lo: 0.0;
    in-out property <float>  panscan-hi: 255.0;
    in-out property <string> panscan-min-x: "";
    in-out property <string> panscan-max-x: "";
    in-out property <string> panscan-min-y: "";
    in-out property <string> panscan-max-y: "";

    // ── Callbacks (Rust-visible) ──────────────────────────────────────────────
    callback quit();
    callback close-left-tab(int);
    callback new-project();
    callback add-tab-3d();
    callback add-tab-2d();
    callback add-tab-camera();
    callback close-project();
    callback open-file(string);
    callback project-tree-selected(int);
    callback navigate-to(string);
    callback snap-requested();
    callback live-toggled(bool);
    callback camera-panned(float, float);
    callback camera-scrolled(float);
    callback camera-settings-changed();
    callback left-tab-activated(int);
    callback close-right-top-tab(int);
    callback right-top-tab-activated(int);
    callback close-right-bottom-tab(int);
    callback right-bottom-tab-activated(int);
    callback move-left-tab(int, int);
    callback move-right-top-tab(int, int);
    callback move-right-bottom-tab(int, int);
    callback add-pane(int, int);
    callback add-pane-at-default(int);
    callback tab-action-left(int, int);
    callback tab-action-right-top(int, int);
    callback tab-action-right-bottom(int, int);
    callback viewer2d-object-selected(int, int);
    callback viewer2d-panned(float, float);
    callback viewer2d-scrolled(float);
    callback viewer2d-settings-changed();
    callback viewer2d-z-changed(float);
    callback viewer3d-panned(float, float);
    callback viewer3d-scrolled(float);
    callback panscan-panned(float, float);
    callback panscan-scrolled(float);
    callback panscan-settings-changed();
    callback panscan-set-corner();
    callback panscan-reset();
    callback panscan-record();
    callback panscan-field-edited(int, string);

    changed active-left-tab        => { root.left-tab-activated(root.active-left-tab); }
    changed active-right-top-tab    => { root.right-top-tab-activated(root.active-right-top-tab); }
    changed active-right-bottom-tab => { root.right-bottom-tab-activated(root.active-right-bottom-tab); }

    // ── Private menu state ────────────────────────────────────────────────────
    private property <bool> file-menu-open: false;
    private property <bool> view-menu-open: false;
    private property <bool> help-menu-open: false;
    private property <bool> about-open: false;

    // ── Main layout ───────────────────────────────────────────────────────────
    VerticalLayout {
        // Menubar
        Rectangle {
            height: 36px;
            background: #2B2B2B;

            HorizontalLayout {
                padding: 4px;
                spacing: 2px;
                alignment: start;

                Rectangle {
                    width: 60px; height: 28px;
                    background: file-btn.has-hover ? #3D3D3D : transparent;
                    border-radius: 3px;
                    file-btn := TouchArea {
                        clicked => {
                            root.about-open = false;
                            root.view-menu-open = false;
                            root.help-menu-open = false;
                            root.file-menu-open = !root.file-menu-open;
                        }
                    }
                    Text { text: "File"; color: white;
                           horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    width: 60px; height: 28px;
                    background: view-btn.has-hover ? #3D3D3D : transparent;
                    border-radius: 3px;
                    view-btn := TouchArea {
                        clicked => {
                            root.about-open = false;
                            root.file-menu-open = false;
                            root.help-menu-open = false;
                            root.view-menu-open = !root.view-menu-open;
                        }
                    }
                    Text { text: "View"; color: white;
                           horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    width: 60px; height: 28px;
                    background: help-btn.has-hover ? #3D3D3D : transparent;
                    border-radius: 3px;
                    help-btn := TouchArea {
                        clicked => {
                            root.about-open = false;
                            root.file-menu-open = false;
                            root.view-menu-open = false;
                            root.help-menu-open = !root.help-menu-open;
                        }
                    }
                    Text { text: "Help"; color: white;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        // Content area
        HorizontalLayout {
            vertical-stretch: 1;

            // Left pane
            LeftPane {
                horizontal-stretch: 1;
                teapot-image:              root.teapot-image;
                camera-image:              root.camera-image;
                viewer2d-image:            root.viewer2d-image;
                viewer2d-image-loaded   <=> root.viewer2d-image-loaded;
                viewer2d-lo             <=> root.viewer2d-lo;
                viewer2d-hi             <=> root.viewer2d-hi;
                viewer2d-z              <=> root.viewer2d-z;
                viewer2d-z-max          <=> root.viewer2d-z-max;
                live-snap               <=> root.live-snap;
                camera-lo               <=> root.camera-lo;
                camera-hi               <=> root.camera-hi;
                left-tabs               <=> root.left-tabs;
                active-left-tab         <=> root.active-left-tab;
                project-tree:              root.project-tree;
                device-props:              root.device-props;
                file-list:                 root.file-list;
                current-path:              root.current-path;
                selected-project-id     <=> root.selected-project-id;
                close-left-tab(i)          => { root.close-left-tab(i); }
                move-left-tab(i, t)        => { root.move-left-tab(i, t); }
                add-pane(a, t)             => { root.add-pane(a, t); }
                tab-action-left(i, a)      => { root.tab-action-left(i, a); }
                viewer3d-panned(dx, dy)    => { root.viewer3d-panned(dx, dy); }
                viewer3d-scrolled(d)       => { root.viewer3d-scrolled(d); }
                viewer2d-panned(dx, dy)    => { root.viewer2d-panned(dx, dy); }
                viewer2d-scrolled(d)       => { root.viewer2d-scrolled(d); }
                viewer2d-settings-changed()          => { root.viewer2d-settings-changed(); }
                viewer2d-z-changed(v)                => { root.viewer2d-z-changed(v); }
                viewer2d-object-selected(pid, oid)   => { root.viewer2d-object-selected(pid, oid); }
                snap-requested()           => { root.snap-requested(); }
                live-toggled(v)            => { root.live-toggled(v); }
                camera-panned(dx, dy)      => { root.camera-panned(dx, dy); }
                camera-scrolled(d)         => { root.camera-scrolled(d); }
                camera-settings-changed()  => { root.camera-settings-changed(); }
                close-project()            => { root.close-project(); }
                project-tree-selected(id)  => { root.project-tree-selected(id); }
                navigate-to(p)             => { root.navigate-to(p); }
                open-file(f)               => { root.open-file(f); }
                panscan-image:                 root.panscan-image;
                panscan-lo              <=>    root.panscan-lo;
                panscan-hi              <=>    root.panscan-hi;
                panscan-min-x           <=>    root.panscan-min-x;
                panscan-max-x           <=>    root.panscan-max-x;
                panscan-min-y           <=>    root.panscan-min-y;
                panscan-max-y           <=>    root.panscan-max-y;
                panscan-panned(dx, dy)         => { root.panscan-panned(dx, dy); }
                panscan-scrolled(d)            => { root.panscan-scrolled(d); }
                panscan-settings-changed()     => { root.panscan-settings-changed(); }
                panscan-set-corner()           => { root.panscan-set-corner(); }
                panscan-reset()                => { root.panscan-reset(); }
                panscan-record()               => { root.panscan-record(); }
                panscan-field-edited(f, t)     => { root.panscan-field-edited(f, t); }
            }

            // Right pane
            VerticalLayout {
                horizontal-stretch: 1;

                RightTopPane {
                    vertical-stretch: 1;
                    teapot-image:              root.teapot-image;
                    camera-image:              root.camera-image;
                    viewer2d-image:            root.viewer2d-image;
                    viewer2d-image-loaded   <=> root.viewer2d-image-loaded;
                    viewer2d-lo             <=> root.viewer2d-lo;
                    viewer2d-hi             <=> root.viewer2d-hi;
                    viewer2d-z              <=> root.viewer2d-z;
                    viewer2d-z-max          <=> root.viewer2d-z-max;
                    live-snap               <=> root.live-snap;
                    camera-lo               <=> root.camera-lo;
                    camera-hi               <=> root.camera-hi;
                    tabs                    <=> root.right-top-tabs;
                    active-tab              <=> root.active-right-top-tab;
                    project-tree:              root.project-tree;
                    device-props:              root.device-props;
                    file-list:                 root.file-list;
                    current-path:              root.current-path;
                    selected-project-id     <=> root.selected-project-id;
                    close-tab(i)               => { root.close-right-top-tab(i); }
                    move-tab(i, t)             => { root.move-right-top-tab(i, t); }
                    add-pane(a, t)             => { root.add-pane(a, t); }
                    tab-action(i, a)           => { root.tab-action-right-top(i, a); }
                    viewer3d-panned(dx, dy)    => { root.viewer3d-panned(dx, dy); }
                    viewer3d-scrolled(d)       => { root.viewer3d-scrolled(d); }
                    viewer2d-panned(dx, dy)    => { root.viewer2d-panned(dx, dy); }
                    viewer2d-scrolled(d)       => { root.viewer2d-scrolled(d); }
                    viewer2d-settings-changed()          => { root.viewer2d-settings-changed(); }
                    viewer2d-z-changed(v)                => { root.viewer2d-z-changed(v); }
                    viewer2d-object-selected(pid, oid)   => { root.viewer2d-object-selected(pid, oid); }
                    snap-requested()           => { root.snap-requested(); }
                    live-toggled(v)            => { root.live-toggled(v); }
                    camera-panned(dx, dy)      => { root.camera-panned(dx, dy); }
                    camera-scrolled(d)         => { root.camera-scrolled(d); }
                    camera-settings-changed()  => { root.camera-settings-changed(); }
                    close-project()            => { root.close-project(); }
                    project-tree-selected(id)  => { root.project-tree-selected(id); }
                    navigate-to(p)             => { root.navigate-to(p); }
                    open-file(f)               => { root.open-file(f); }
                    panscan-image:                 root.panscan-image;
                    panscan-lo              <=>    root.panscan-lo;
                    panscan-hi              <=>    root.panscan-hi;
                    panscan-min-x           <=>    root.panscan-min-x;
                    panscan-max-x           <=>    root.panscan-max-x;
                    panscan-min-y           <=>    root.panscan-min-y;
                    panscan-max-y           <=>    root.panscan-max-y;
                    panscan-panned(dx, dy)         => { root.panscan-panned(dx, dy); }
                    panscan-scrolled(d)            => { root.panscan-scrolled(d); }
                    panscan-settings-changed()     => { root.panscan-settings-changed(); }
                    panscan-set-corner()           => { root.panscan-set-corner(); }
                    panscan-reset()                => { root.panscan-reset(); }
                    panscan-record()               => { root.panscan-record(); }
                    panscan-field-edited(f, t)     => { root.panscan-field-edited(f, t); }
                }

                Rectangle { height: 1px; background: #444444; }

                RightBottomPane {
                    vertical-stretch: 1;
                    teapot-image:              root.teapot-image;
                    camera-image:              root.camera-image;
                    viewer2d-image:            root.viewer2d-image;
                    viewer2d-image-loaded   <=> root.viewer2d-image-loaded;
                    viewer2d-lo             <=> root.viewer2d-lo;
                    viewer2d-hi             <=> root.viewer2d-hi;
                    viewer2d-z              <=> root.viewer2d-z;
                    viewer2d-z-max          <=> root.viewer2d-z-max;
                    live-snap               <=> root.live-snap;
                    camera-lo               <=> root.camera-lo;
                    camera-hi               <=> root.camera-hi;
                    tabs                    <=> root.right-bottom-tabs;
                    active-tab              <=> root.active-right-bottom-tab;
                    project-tree:              root.project-tree;
                    device-props:              root.device-props;
                    file-list:                 root.file-list;
                    current-path:              root.current-path;
                    selected-project-id     <=> root.selected-project-id;
                    close-tab(i)               => { root.close-right-bottom-tab(i); }
                    move-tab(i, t)             => { root.move-right-bottom-tab(i, t); }
                    add-pane(a, t)             => { root.add-pane(a, t); }
                    tab-action(i, a)           => { root.tab-action-right-bottom(i, a); }
                    viewer3d-panned(dx, dy)    => { root.viewer3d-panned(dx, dy); }
                    viewer3d-scrolled(d)       => { root.viewer3d-scrolled(d); }
                    viewer2d-panned(dx, dy)    => { root.viewer2d-panned(dx, dy); }
                    viewer2d-scrolled(d)       => { root.viewer2d-scrolled(d); }
                    viewer2d-settings-changed()          => { root.viewer2d-settings-changed(); }
                    viewer2d-z-changed(v)                => { root.viewer2d-z-changed(v); }
                    viewer2d-object-selected(pid, oid)   => { root.viewer2d-object-selected(pid, oid); }
                    snap-requested()           => { root.snap-requested(); }
                    live-toggled(v)            => { root.live-toggled(v); }
                    camera-panned(dx, dy)      => { root.camera-panned(dx, dy); }
                    camera-scrolled(d)         => { root.camera-scrolled(d); }
                    camera-settings-changed()  => { root.camera-settings-changed(); }
                    close-project()            => { root.close-project(); }
                    project-tree-selected(id)  => { root.project-tree-selected(id); }
                    navigate-to(p)             => { root.navigate-to(p); }
                    open-file(f)               => { root.open-file(f); }
                    panscan-image:                 root.panscan-image;
                    panscan-lo              <=>    root.panscan-lo;
                    panscan-hi              <=>    root.panscan-hi;
                    panscan-min-x           <=>    root.panscan-min-x;
                    panscan-max-x           <=>    root.panscan-max-x;
                    panscan-min-y           <=>    root.panscan-min-y;
                    panscan-max-y           <=>    root.panscan-max-y;
                    panscan-panned(dx, dy)         => { root.panscan-panned(dx, dy); }
                    panscan-scrolled(d)            => { root.panscan-scrolled(d); }
                    panscan-settings-changed()     => { root.panscan-settings-changed(); }
                    panscan-set-corner()           => { root.panscan-set-corner(); }
                    panscan-reset()                => { root.panscan-reset(); }
                    panscan-record()               => { root.panscan-record(); }
                    panscan-field-edited(f, t)     => { root.panscan-field-edited(f, t); }
                }
            }
        }
    }

    // ── Dismiss overlay (behind dropdowns) ────────────────────────────────────
    if root.file-menu-open || root.view-menu-open || root.help-menu-open: Rectangle {
        z: 1;
        width: root.width;
        height: root.height;
        background: transparent;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.file-menu-open = false;
                root.view-menu-open = false;
                root.help-menu-open = false;
            }
        }
    }

    // ── File dropdown ─────────────────────────────────────────────────────────
    if root.file-menu-open: Rectangle {
        z: 2;
        x: 4px;
        y: 36px;
        width: 120px;
        height: file-drop.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;

        file-drop := VerticalLayout {
            Rectangle {
                height: 30px;
                background: new-item.has-hover ? #3D3D3D : transparent;
                new-item := TouchArea {
                    clicked => {
                        root.file-menu-open = false;
                        root.new-project();
                    }
                }
                Text { text: "New"; color: white; height: parent.height;
                       vertical-alignment: center; x: 8px; }
            }
            Rectangle {
                height: 30px;
                background: quit-item.has-hover ? #3D3D3D : transparent;
                quit-item := TouchArea {
                    clicked => { root.quit(); }
                }
                Text {
                    text: root.server-mode ? "Shut down server" : "Quit";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
        }
    }

    // ── View dropdown ─────────────────────────────────────────────────────────
    if root.view-menu-open: Rectangle {
        z: 2;
        x: 66px;
        y: 36px;
        width: 160px;
        height: view-drop.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;

        view-drop := VerticalLayout {
            Rectangle { height: 30px; background: vm0.has-hover ? #3D3D3D : transparent;
                vm0 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(0); } }
                Text { text: "3D View";           color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
            Rectangle { height: 30px; background: vm1.has-hover ? #3D3D3D : transparent;
                vm1 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(1); } }
                Text { text: "2D Viewer";          color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
            Rectangle { height: 30px; background: vm2.has-hover ? #3D3D3D : transparent;
                vm2 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(2); } }
                Text { text: "Camera";             color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
            Rectangle { height: 1px; background: #444444; }
            Rectangle { height: 30px; background: vm3.has-hover ? #3D3D3D : transparent;
                vm3 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(3); } }
                Text { text: "Cam Properties";    color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
            Rectangle { height: 30px; background: vm4.has-hover ? #3D3D3D : transparent;
                vm4 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(4); } }
                Text { text: "Particle Tracking"; color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
            Rectangle { height: 1px; background: #444444; }
            Rectangle { height: 30px; background: vm5.has-hover ? #3D3D3D : transparent;
                vm5 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(5); } }
                Text { text: "Project";            color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
            Rectangle { height: 30px; background: vm6.has-hover ? #3D3D3D : transparent;
                vm6 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(6); } }
                Text { text: "Files";              color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
            Rectangle { height: 30px; background: vm7.has-hover ? #3D3D3D : transparent;
                vm7 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(7); } }
                Text { text: "Plots";              color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
            Rectangle { height: 30px; background: vm8.has-hover ? #3D3D3D : transparent;
                vm8 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(8); } }
                Text { text: "Help";               color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
            Rectangle { height: 1px; background: #444444; }
            Rectangle { height: 30px; background: vm9.has-hover ? #3D3D3D : transparent;
                vm9 := TouchArea { clicked => { root.view-menu-open = false; root.add-pane-at-default(9); } }
                Text { text: "Panorama scan";      color: white; height: parent.height; vertical-alignment: center; x: 8px; } }
        }
    }

    // ── Help dropdown ─────────────────────────────────────────────────────────
    if root.help-menu-open: Rectangle {
        z: 2;
        x: 128px;
        y: 36px;
        width: 120px;
        height: help-drop.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;

        help-drop := VerticalLayout {
            Rectangle {
                height: 30px;
                background: about-item.has-hover ? #3D3D3D : transparent;
                about-item := TouchArea {
                    clicked => {
                        root.help-menu-open = false;
                        root.about-open = true;
                    }
                }
                Text { text: "About"; color: white; height: parent.height;
                       vertical-alignment: center; x: 8px; }
            }
        }
    }

    // ── Error backdrop ────────────────────────────────────────────────────────
    if root.error-message != "": Rectangle {
        z: 10;
        width: root.width;
        height: root.height;
        background: #00000080;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.error-message = ""; }
        }
    }

    // ── Error dialog ──────────────────────────────────────────────────────────
    if root.error-message != "": Rectangle {
        z: 11;
        width: 320px;
        height: err-layout.preferred-height + 48px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #884444;
        border-radius: 4px;

        TouchArea { width: parent.width; height: parent.height; }

        err-layout := VerticalLayout {
            padding: 24px;
            spacing: 8px;

            Text { text: "Cannot open file"; font-size: 16px; color: #FF6666; }
            Text { text: root.error-message; color: #CCCCCC; font-size: 12px; wrap: word-wrap; }
            Rectangle { height: 8px; }

            Rectangle {
                height: 32px;
                width: 60px;
                background: err-ok-btn.has-hover ? #3D3D3D : #444444;
                border-radius: 3px;
                err-ok-btn := TouchArea {
                    clicked => { root.error-message = ""; }
                }
                Text { text: "OK"; color: white;
                       horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }

    // ── About backdrop ────────────────────────────────────────────────────────
    if root.about-open: Rectangle {
        z: 10;
        width: root.width;
        height: root.height;
        background: #00000080;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.about-open = false; }
        }
    }

    // ── About dialog ──────────────────────────────────────────────────────────
    if root.about-open: Rectangle {
        z: 11;
        width: 280px;
        height: about-layout.preferred-height + 48px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;
        border-radius: 4px;

        TouchArea { width: parent.width; height: parent.height; }

        about-layout := VerticalLayout {
            padding: 24px;
            spacing: 8px;

            Text { text: "About"; font-size: 20px; color: white; }
            Text { text: "Work in progress"; color: white; }
            Rectangle { height: 8px; }

            Rectangle {
                height: 32px;
                width: 60px;
                background: ok-btn.has-hover ? #3D3D3D : #444444;
                border-radius: 3px;
                ok-btn := TouchArea {
                    clicked => { root.about-open = false; }
                }
                Text { text: "OK"; color: white;
                       horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
}
