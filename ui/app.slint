
struct FileEntry {
    name: string,
    is-dir: bool,
    size: string,
}

struct DevicePropEntry {
    device: string,
    property: string,
    value: string,
}

export component AppWindow inherits Window {
    title: "RIPP — Rust Imaging Processing Platform";
    min-width: 640px;
    min-height: 400px;

    // Set by Rust each frame
    in property <image> teapot-image;
    in property <image> camera-image;

    // Internal UI state
    private property <bool> file-menu-open: false;
    private property <bool> help-menu-open: false;
    private property <bool> about-open: false;

    in property <bool> server-mode: false;
    in property <[FileEntry]> file-list;
    in property <string> current-path: ".";
    in property <[DevicePropEntry]> device-props;

    // Only actions that need Rust
    callback quit();
    callback navigate-to(string);

    private property <int> active-tab: 0;      // 0=Files, 1=Plots, 2=Help
    private property <int> active-left-tab: 0; // 0=3D View, 1=Camera

    // Column widths for device properties table
    private property <length> dp-col1-width: 100px;
    private property <length> dp-col3-width: 120px;
    private property <length> dp-drag1: 0;
    private property <length> dp-drag3: 0;

    // Column widths for file list table
    private property <length> file-size-width: 72px;
    private property <length> file-drag: 0;

    // ── Main layout ──────────────────────────────────────────────────────────
    VerticalLayout {
        // Menubar
        Rectangle {
            height: 36px;
            background: #2B2B2B;

            HorizontalLayout {
                padding: 4px;
                spacing: 2px;
                alignment: start;

                Rectangle {
                    width: 60px;
                    height: 28px;
                    background: file-btn.has-hover ? #3D3D3D : transparent;
                    border-radius: 3px;
                    file-btn := TouchArea {
                        clicked => {
                            root.about-open = false;
                            root.help-menu-open = false;
                            root.file-menu-open = !root.file-menu-open;
                        }
                    }
                    Text {
                        text: "File";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 60px;
                    height: 28px;
                    background: help-btn.has-hover ? #3D3D3D : transparent;
                    border-radius: 3px;
                    help-btn := TouchArea {
                        clicked => {
                            root.about-open = false;
                            root.file-menu-open = false;
                            root.help-menu-open = !root.help-menu-open;
                        }
                    }
                    Text {
                        text: "Help";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Content area
        HorizontalLayout {
            vertical-stretch: 1;

            // Left pane: tabbed
            VerticalLayout {
                horizontal-stretch: 1;

                // Tab bar
                Rectangle {
                    height: 28px;
                    background: #222222;
                    HorizontalLayout {
                        spacing: 0px;
                        alignment: start;

                        Rectangle {
                            width: 70px;
                            height: 28px;
                            background: root.active-left-tab == 0 ? #3A3A3A : #222222;
                            ltab0-btn := TouchArea { clicked => { root.active-left-tab = 0; } }
                            Text {
                                text: "3D View";
                                color: white;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 70px;
                            height: 28px;
                            background: root.active-left-tab == 1 ? #3A3A3A : #222222;
                            ltab1-btn := TouchArea { clicked => { root.active-left-tab = 1; } }
                            Text {
                                text: "Camera";
                                color: white;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // 3D View tab
                if root.active-left-tab == 0: Image {
                    source: root.teapot-image;
                    vertical-stretch: 1;
                    image-fit: fill;
                }

                // Camera tab
                if root.active-left-tab == 1: Image {
                    source: root.camera-image;
                    vertical-stretch: 1;
                    image-fit: contain;
                }
            }

            // Right pane: split vertically
            VerticalLayout {
                horizontal-stretch: 1;

                // Top: Device properties table
                VerticalLayout {
                    vertical-stretch: 1;

                    // Column header
                    Rectangle {
                        height: 20px;
                        background: #000000;
                        HorizontalLayout {
                            padding-left: 4px;
                            padding-right: 4px;
                            Text { text: "Device";   color: #888888; font-size: 11px; vertical-alignment: center; width: root.dp-col1-width; overflow: elide; }
                            Rectangle {
                                width: 5px; height: parent.height;
                                background: dph1.pressed ? #666666 : (dph1.has-hover ? #444444 : transparent);
                                dph1 := TouchArea {
                                    mouse-cursor: col-resize;
                                    pointer-event(e) => { if (e.kind == PointerEventKind.down) { root.dp-drag1 = self.mouse-x; } }
                                    moved => { root.dp-col1-width = max(40px, root.dp-col1-width + self.mouse-x - root.dp-drag1); }
                                }
                            }
                            Text { text: "Property"; color: #888888; font-size: 11px; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                            Rectangle {
                                width: 5px; height: parent.height;
                                background: dph3.pressed ? #666666 : (dph3.has-hover ? #444444 : transparent);
                                dph3 := TouchArea {
                                    mouse-cursor: col-resize;
                                    pointer-event(e) => { if (e.kind == PointerEventKind.down) { root.dp-drag3 = self.mouse-x; } }
                                    moved => { root.dp-col3-width = max(40px, root.dp-col3-width - (self.mouse-x - root.dp-drag3)); }
                                }
                            }
                            Text { text: "Value";    color: #888888; font-size: 11px; vertical-alignment: center; width: root.dp-col3-width; overflow: elide; }
                        }
                    }
                    Rectangle { height: 1px; background: #2A2A2A; }

                    Rectangle {
                        vertical-stretch: 1;
                        background: #000000;
                        clip: true;

                        prop-flick := Flickable {
                            width: parent.width - 8px;
                            height: parent.height;
                            viewport-height: prop-entries.preferred-height;

                            prop-entries := VerticalLayout {
                                for entry in root.device-props: Rectangle {
                                    height: 22px;
                                    background: prop-row.has-hover ? #1E1E1E : #000000;
                                    prop-row := TouchArea {}
                                    HorizontalLayout {
                                        padding-left: 4px;
                                        padding-right: 4px;
                                        spacing: 0px;
                                        Text { text: entry.device;   color: #6699CC; font-size: 12px; vertical-alignment: center; width: root.dp-col1-width; overflow: elide; }
                                        Rectangle { width: 5px; }
                                        Text { text: entry.property; color: #CCCCCC; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                                        Rectangle { width: 5px; }
                                        Text { text: entry.value;    color: #AAAAAA; font-size: 12px; vertical-alignment: center; width: root.dp-col3-width; overflow: elide; }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            x: parent.width - 6px;
                            width: 6px;
                            height: parent.height;
                            background: #111111;
                            Rectangle {
                                visible: prop-flick.viewport-height > prop-flick.height;
                                width: 4px;
                                x: 1px;
                                y: (-prop-flick.viewport-y / prop-flick.viewport-height) * parent.height;
                                height: max(20px, (prop-flick.height / prop-flick.viewport-height) * parent.height);
                                background: #555555;
                                border-radius: 2px;
                            }
                        }
                    }
                }

                // Divider
                Rectangle { height: 1px; background: #444444; }

                // Bottom: tabbed panel
                VerticalLayout {
                    vertical-stretch: 1;

                    // Tab bar
                    Rectangle {
                        height: 28px;
                        background: #222222;
                        HorizontalLayout {
                            spacing: 0px;
                            alignment: start;

                            Rectangle {
                                width: 60px;
                                height: 28px;
                                background: root.active-tab == 0 ? #3A3A3A : #222222;
                                tab0-btn := TouchArea { clicked => { root.active-tab = 0; } }
                                Text {
                                    text: "Files";
                                    color: white;
                                    font-size: 13px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle {
                                width: 60px;
                                height: 28px;
                                background: root.active-tab == 1 ? #3A3A3A : #222222;
                                tab1-btn := TouchArea { clicked => { root.active-tab = 1; } }
                                Text {
                                    text: "Plots";
                                    color: white;
                                    font-size: 13px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle {
                                width: 60px;
                                height: 28px;
                                background: root.active-tab == 2 ? #3A3A3A : #222222;
                                tab2-btn := TouchArea { clicked => { root.active-tab = 2; } }
                                Text {
                                    text: "Help";
                                    color: white;
                                    font-size: 13px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Files tab
                    if root.active-tab == 0: VerticalLayout {
                        vertical-stretch: 1;

                        // Path bar
                        Rectangle {
                            height: 26px;
                            background: #1E1E1E;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                spacing: 4px;

                                // Up button
                                Rectangle {
                                    width: 28px;
                                    background: up-btn.has-hover ? #3A3A3A : #2A2A2A;
                                    border-radius: 3px;
                                    up-btn := TouchArea {
                                        clicked => { root.navigate-to(".."); }
                                    }
                                    Text {
                                        text: "↑";
                                        color: #AAAAAA;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    text: root.current-path;
                                    color: #AAAAAA;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        Rectangle { height: 1px; background: #333333; }

                        // Table header
                        Rectangle {
                            height: 20px;
                            background: #000000;
                            HorizontalLayout {
                                padding-left: 24px;  // 8px margin + 12px icon + 4px gap
                                padding-right: 4px;
                                Text {
                                    text: "Name";
                                    color: #888888;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                Rectangle {
                                    width: 5px; height: parent.height;
                                    background: fh.pressed ? #666666 : (fh.has-hover ? #444444 : transparent);
                                    fh := TouchArea {
                                        mouse-cursor: col-resize;
                                        pointer-event(e) => { if (e.kind == PointerEventKind.down) { root.file-drag = self.mouse-x; } }
                                        moved => { root.file-size-width = max(40px, root.file-size-width - (self.mouse-x - root.file-drag)); }
                                    }
                                }
                                Text {
                                    text: "Size";
                                    color: #888888;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    width: root.file-size-width;
                                    horizontal-alignment: right;
                                }
                            }
                        }
                        Rectangle { height: 1px; background: #2A2A2A; }

                        // File list with custom scrollbar (Flickable avoids native frame)
                        Rectangle {
                            vertical-stretch: 1;
                            background: #000000;
                            clip: true;

                            file-flick := Flickable {
                                width: parent.width - 8px;
                                height: parent.height;
                                viewport-height: file-entries.preferred-height;

                                file-entries := VerticalLayout {
                                    for entry in root.file-list: Rectangle {
                                        height: 22px;
                                        background: entry-area.has-hover ? #1E1E1E : #000000;
                                        entry-area := TouchArea {
                                            clicked => {
                                                if (entry.is-dir) {
                                                    root.navigate-to(entry.name);
                                                }
                                            }
                                        }
                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 4px;
                                            spacing: 4px;
                                            Text {
                                                text: entry.is-dir ? "▶" : " ";
                                                color: #6699CC;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                                width: 12px;
                                            }
                                            Text {
                                                text: entry.name;
                                                color: entry.is-dir ? #9ABFDD : #CCCCCC;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: entry.size;
                                                color: #777777;
                                                font-size: 12px;
                                                vertical-alignment: center;
                                                width: root.file-size-width;
                                                horizontal-alignment: right;
                                            }
                                        }
                                    }
                                }
                            }

                            // Custom scrollbar track
                            Rectangle {
                                x: parent.width - 6px;
                                width: 6px;
                                height: parent.height;
                                background: #111111;

                                // Thumb — only visible when content overflows
                                Rectangle {
                                    visible: file-flick.viewport-height > file-flick.height;
                                    width: 4px;
                                    x: 1px;
                                    y: (-file-flick.viewport-y / file-flick.viewport-height) * parent.height;
                                    height: max(20px, (file-flick.height / file-flick.viewport-height) * parent.height);
                                    background: #555555;
                                    border-radius: 2px;
                                }
                            }
                        }
                    }

                    // Plots tab
                    if root.active-tab == 1: Rectangle {
                        vertical-stretch: 1;
                        background: #111111;
                    }

                    // Help tab
                    if root.active-tab == 2: Rectangle {
                        vertical-stretch: 1;
                        background: #111111;
                    }
                }
            }

        }
    }

    // ── Dismiss overlay (behind dropdowns) ───────────────────────────────────
    if root.file-menu-open || root.help-menu-open: Rectangle {
        z: 1;
        width: root.width;
        height: root.height;
        background: transparent;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.file-menu-open = false;
                root.help-menu-open = false;
            }
        }
    }

    // ── File dropdown ─────────────────────────────────────────────────────────
    if root.file-menu-open: Rectangle {
        z: 2;
        x: 4px;
        y: 36px;
        width: 120px;
        height: file-drop.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;

        file-drop := VerticalLayout {
            Rectangle {
                height: 30px;
                background: new-item.has-hover ? #3D3D3D : transparent;
                new-item := TouchArea {
                    clicked => { root.file-menu-open = false; }
                }
                Text {
                    text: "New";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
            Rectangle {
                height: 30px;
                background: quit-item.has-hover ? #3D3D3D : transparent;
                quit-item := TouchArea {
                    clicked => { root.quit(); }
                }
                Text {
                    text: root.server-mode ? "Shut down server" : "Quit";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
        }
    }

    // ── Help dropdown ─────────────────────────────────────────────────────────
    if root.help-menu-open: Rectangle {
        z: 2;
        x: 66px;
        y: 36px;
        width: 120px;
        height: help-drop.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;

        help-drop := VerticalLayout {
            Rectangle {
                height: 30px;
                background: about-item.has-hover ? #3D3D3D : transparent;
                about-item := TouchArea {
                    clicked => {
                        root.help-menu-open = false;
                        root.about-open = true;
                    }
                }
                Text {
                    text: "About";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
        }
    }

    // ── About backdrop ────────────────────────────────────────────────────────
    if root.about-open: Rectangle {
        z: 10;
        width: root.width;
        height: root.height;
        background: #00000080;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.about-open = false; }
        }
    }

    // ── About dialog ──────────────────────────────────────────────────────────
    if root.about-open: Rectangle {
        z: 11;
        width: 280px;
        height: about-layout.preferred-height + 48px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;
        border-radius: 4px;

        // absorb clicks so backdrop TouchArea doesn't fire
        TouchArea { width: parent.width; height: parent.height; }

        about-layout := VerticalLayout {
            padding: 24px;
            spacing: 8px;

            Text { text: "About"; font-size: 20px; color: white; }
            Text { text: "Work in progress"; color: white; }
            Rectangle { height: 8px; }

            Rectangle {
                height: 32px;
                width: 60px;
                background: ok-btn.has-hover ? #3D3D3D : #444444;
                border-radius: 3px;
                ok-btn := TouchArea {
                    clicked => { root.about-open = false; }
                }
                Text {
                    text: "OK";
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
