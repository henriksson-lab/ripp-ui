import { Slider } from "std-widgets.slint";

struct FileEntry {
    name: string,
    is-dir: bool,
    size: string,
}

struct DevicePropEntry {
    device: string,
    property: string,
    value: string,
}

struct LeftTabEntry {
    label: string,
    tab-type: int,   // 0=3D View, 1=2D Viewer, 2=Camera
}

struct ProjectTreeEntry {
    label: string,
    indent: int,
    object-id: int,
    project-id: int,
}

export component AppWindow inherits Window {
    title: "RIPP — Rust Imaging Processing Platform";
    min-width: 640px;
    min-height: 400px;

    // Set by Rust each frame
    in property <image> teapot-image;
    in property <image> camera-image;

    // Internal UI state
    private property <bool> file-menu-open: false;
    private property <bool> help-menu-open: false;
    private property <bool> about-open: false;

    in property <bool> server-mode: false;
    in-out property <string> error-message: "";
    in property <[FileEntry]> file-list;
    in property <string> current-path: ".";
    in property <[DevicePropEntry]> device-props;
    in property <[ProjectTreeEntry]> project-tree;

    // Only actions that need Rust
    callback quit();
    callback close-left-tab(int);
    callback new-project();
    callback close-project();
    callback open-file(string);   // passes selected filename (not full path)
    callback project-tree-selected(int);  // passes object-id
    private property <int> selected-row: -1;
    in-out property <int> selected-project-id: -1;
    callback navigate-to(string);
    callback snap-requested();
    callback live-toggled(bool);
    callback camera-panned(float, float);
    callback camera-scrolled(float);
    private property <bool> live-snap: false;
    private property <float> cam-drag-x;
    private property <float> cam-drag-y;

    in-out property <int> active-tab: 0;      // 0=Project, 1=Files, 2=Plots, 3=Help
    in-out property <int> active-left-tab: 0;
    in-out property <[LeftTabEntry]> left-tabs;
    private property <bool> viewer2d-dropdown-open: false;
    private property <int>  viewer2d-selected-row: -1;
    private property <string> viewer2d-selected-label: "";
    in property <image> viewer2d-image;
    in-out property <bool> viewer2d-image-loaded: false;
    callback viewer2d-object-selected(int, int);  // project-id, object-id
    in-out property <float> viewer2d-brightness: 0.0;   // -1..1
    in-out property <float> viewer2d-contrast: 1.0;     // 0..4
    callback viewer2d-panned(float, float);
    callback viewer2d-scrolled(float);
    callback viewer2d-settings-changed();
    private property <float> v2d-drag-x;
    private property <float> v2d-drag-y;

    // Column widths for device properties table
    private property <length> dp-col1-width: 100px;
    private property <length> dp-col3-width: 120px;
    private property <length> dp-drag1: 0;
    private property <length> dp-drag3: 0;

    // Column widths for file list table
    private property <length> file-size-width: 72px;
    private property <length> file-drag: 0;
    private property <int> selected-file-row: -1;
    private property <bool> selected-file-is-dir: false;

    // ── Main layout ──────────────────────────────────────────────────────────
    VerticalLayout {
        // Menubar
        Rectangle {
            height: 36px;
            background: #2B2B2B;

            HorizontalLayout {
                padding: 4px;
                spacing: 2px;
                alignment: start;

                Rectangle {
                    width: 60px;
                    height: 28px;
                    background: file-btn.has-hover ? #3D3D3D : transparent;
                    border-radius: 3px;
                    file-btn := TouchArea {
                        clicked => {
                            root.about-open = false;
                            root.help-menu-open = false;
                            root.file-menu-open = !root.file-menu-open;
                        }
                    }
                    Text {
                        text: "File";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 60px;
                    height: 28px;
                    background: help-btn.has-hover ? #3D3D3D : transparent;
                    border-radius: 3px;
                    help-btn := TouchArea {
                        clicked => {
                            root.about-open = false;
                            root.file-menu-open = false;
                            root.help-menu-open = !root.help-menu-open;
                        }
                    }
                    Text {
                        text: "Help";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Content area
        HorizontalLayout {
            vertical-stretch: 1;

            // Left pane: tabbed
            VerticalLayout {
                horizontal-stretch: 1;

                // Tab bar
                Rectangle {
                    height: 28px;
                    background: #222222;
                    HorizontalLayout {
                        spacing: 0px;
                        alignment: start;

                        for tab[i] in root.left-tabs: Rectangle {
                            width: 94px;
                            height: 28px;
                            background: root.active-left-tab == i ? #3A3A3A : #222222;
                            ltab-btn := TouchArea { clicked => { root.active-left-tab = i; } }
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 2px;
                                spacing: 2px;
                                Text {
                                    text: tab.label;
                                    color: white;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Rectangle {
                                    width: 16px;
                                    height: 16px;
                                    border-radius: 3px;
                                    background: close-tab-btn.has-hover ? #555555 : transparent;
                                    close-tab-btn := TouchArea {
                                        clicked => { root.close-left-tab(i); }
                                    }
                                    Text {
                                        text: "×";
                                        color: #AAAAAA;
                                        font-size: 13px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // 3D View tab
                if root.active-left-tab < root.left-tabs.length && root.left-tabs[root.active-left-tab].tab-type == 0: Image {
                    source: root.teapot-image;
                    vertical-stretch: 1;
                    image-fit: fill;
                }

                // Camera tab
                if root.active-left-tab < root.left-tabs.length && root.left-tabs[root.active-left-tab].tab-type == 2: VerticalLayout {
                    vertical-stretch: 1;

                    Rectangle {
                        vertical-stretch: 1;
                        Image {
                            source: root.camera-image;
                            image-fit: contain;
                            width: 100%;
                            height: 100%;
                        }
                        cam-ta := TouchArea {
                            mouse-cursor: crosshair;
                            pointer-event(e) => {
                                if (e.kind == PointerEventKind.down) {
                                    root.cam-drag-x = self.mouse-x / 1px;
                                    root.cam-drag-y = self.mouse-y / 1px;
                                }
                            }
                            moved => {
                                if (self.pressed) {
                                    root.camera-panned(
                                        self.mouse-x / 1px - root.cam-drag-x,
                                        self.mouse-y / 1px - root.cam-drag-y
                                    );
                                    root.cam-drag-x = self.mouse-x / 1px;
                                    root.cam-drag-y = self.mouse-y / 1px;
                                }
                            }
                            scroll-event(e) => {
                                root.camera-scrolled(e.delta-y / 1px);
                                return EventResult.accept;
                            }
                        }
                    }

                    Rectangle {
                        height: 32px;
                        background: #1A1A1A;
                        HorizontalLayout {
                            padding: 4px;
                            spacing: 6px;
                            alignment: start;

                            Rectangle {
                                width: 60px; height: 24px;
                                background: snap-btn.has-hover ? #3D3D3D : #2A2A2A;
                                border-radius: 3px;
                                snap-btn := TouchArea { clicked => { root.snap-requested(); } }
                                Text { text: "Snap"; color: white; font-size: 12px;
                                       horizontal-alignment: center; vertical-alignment: center; }
                            }

                            Rectangle {
                                width: 60px; height: 24px;
                                background: live-btn.has-hover ? #3D3D3D : #2A2A2A;
                                border-radius: 3px;
                                border-width: root.live-snap ? 1px : 0px;
                                border-color: #6699CC;
                                live-btn := TouchArea {
                                    clicked => {
                                        root.live-snap = !root.live-snap;
                                        root.live-toggled(root.live-snap);
                                    }
                                }
                                Text { text: "Live"; font-size: 12px;
                                       color: root.live-snap ? #9ABFDD : white;
                                       horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }
                }

                // 2D Viewer tab
                if root.active-left-tab < root.left-tabs.length && root.left-tabs[root.active-left-tab].tab-type == 1: VerticalLayout {
                    vertical-stretch: 1;

                    // Main view area
                    Rectangle {
                        vertical-stretch: 1;
                        background: #111111;
                        if root.viewer2d-image-loaded: Image {
                            source: root.viewer2d-image;
                            image-fit: contain;
                            width: 100%;
                            height: 100%;
                        }
                        if !root.viewer2d-image-loaded: Text {
                            text: "No image selected";
                            color: #555555;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        v2d-ta := TouchArea {
                            mouse-cursor: crosshair;
                            pointer-event(e) => {
                                if (e.kind == PointerEventKind.down) {
                                    root.v2d-drag-x = self.mouse-x / 1px;
                                    root.v2d-drag-y = self.mouse-y / 1px;
                                }
                            }
                            moved => {
                                if (self.pressed) {
                                    root.viewer2d-panned(
                                        self.mouse-x / 1px - root.v2d-drag-x,
                                        self.mouse-y / 1px - root.v2d-drag-y
                                    );
                                    root.v2d-drag-x = self.mouse-x / 1px;
                                    root.v2d-drag-y = self.mouse-y / 1px;
                                }
                            }
                            scroll-event(e) => {
                                root.viewer2d-scrolled(e.delta-y / 1px);
                                return EventResult.accept;
                            }
                        }
                    }

                    // Brightness / contrast sliders
                    Rectangle {
                        height: 56px;
                        background: #1A1A1A;
                        VerticalLayout {
                            padding: 4px;
                            spacing: 4px;
                            HorizontalLayout {
                                spacing: 6px;
                                Text { text: "B"; color: #888888; font-size: 11px; vertical-alignment: center; width: 14px; }
                                Slider {
                                    minimum: -1.0; maximum: 1.0;
                                    value <=> root.viewer2d-brightness;
                                    horizontal-stretch: 1;
                                    changed(v) => { root.viewer2d-settings-changed(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Text { text: "C"; color: #888888; font-size: 11px; vertical-alignment: center; width: 14px; }
                                Slider {
                                    minimum: 0.0; maximum: 4.0;
                                    value <=> root.viewer2d-contrast;
                                    horizontal-stretch: 1;
                                    changed(v) => { root.viewer2d-settings-changed(); }
                                }
                            }
                        }
                    }

                    // Inline dropdown list (expands upward from the selector bar)
                    if root.viewer2d-dropdown-open: Rectangle {
                        height: min(200px, dd-entries.preferred-height);
                        background: #1E1E1E;
                        border-width: 1px;
                        border-color: #444444;
                        clip: true;

                        dd-flick := Flickable {
                            width: parent.width;
                            height: parent.height;
                            viewport-height: dd-entries.preferred-height;

                            dd-entries := VerticalLayout {
                                for entry[i] in root.project-tree: Rectangle {
                                    height: 22px;
                                    background: dd-row-ta.has-hover ? #2A3A4A
                                              : root.viewer2d-selected-row == i ? #1E3A5F : #1E1E1E;
                                    dd-row-ta := TouchArea {
                                        clicked => {
                                            root.viewer2d-selected-row = i;
                                            root.viewer2d-selected-label = entry.label;
                                            root.viewer2d-dropdown-open = false;
                                            root.viewer2d-object-selected(entry.project-id, entry.object-id);
                                        }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px + entry.indent * 16px;
                                        padding-right: 4px;
                                        Text {
                                            text: entry.label;
                                            color: entry.indent == 0 ? #9ABFDD : #CCCCCC;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Selector bar
                    Rectangle {
                        height: 32px;
                        background: #1A1A1A;
                        HorizontalLayout {
                            padding: 4px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 24px;
                                background: dd-btn.has-hover ? #3A3A3A : #2A2A2A;
                                border-radius: 3px;
                                dd-btn := TouchArea {
                                    clicked => { root.viewer2d-dropdown-open = !root.viewer2d-dropdown-open; }
                                }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    Text {
                                        text: root.viewer2d-selected-label == "" ? "Select object..." : root.viewer2d-selected-label;
                                        color: root.viewer2d-selected-label == "" ? #666666 : #CCCCCC;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: "▼";
                                        color: #888888;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Right pane: split vertically
            VerticalLayout {
                horizontal-stretch: 1;

                // Top: Device properties table
                VerticalLayout {
                    vertical-stretch: 1;

                    // Column header
                    Rectangle {
                        height: 20px;
                        background: #000000;
                        HorizontalLayout {
                            padding-left: 4px;
                            padding-right: 4px;
                            Text { text: "Device";   color: #888888; font-size: 11px; vertical-alignment: center; width: root.dp-col1-width; overflow: elide; }
                            Rectangle {
                                width: 5px; height: parent.height;
                                background: dph1.pressed ? #666666 : (dph1.has-hover ? #444444 : transparent);
                                dph1 := TouchArea {
                                    mouse-cursor: col-resize;
                                    pointer-event(e) => { if (e.kind == PointerEventKind.down) { root.dp-drag1 = self.mouse-x; } }
                                    moved => { root.dp-col1-width = max(40px, root.dp-col1-width + self.mouse-x - root.dp-drag1); }
                                }
                            }
                            Text { text: "Property"; color: #888888; font-size: 11px; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                            Rectangle {
                                width: 5px; height: parent.height;
                                background: dph3.pressed ? #666666 : (dph3.has-hover ? #444444 : transparent);
                                dph3 := TouchArea {
                                    mouse-cursor: col-resize;
                                    pointer-event(e) => { if (e.kind == PointerEventKind.down) { root.dp-drag3 = self.mouse-x; } }
                                    moved => { root.dp-col3-width = max(40px, root.dp-col3-width - (self.mouse-x - root.dp-drag3)); }
                                }
                            }
                            Text { text: "Value";    color: #888888; font-size: 11px; vertical-alignment: center; width: root.dp-col3-width; overflow: elide; }
                        }
                    }
                    Rectangle { height: 1px; background: #2A2A2A; }

                    Rectangle {
                        vertical-stretch: 1;
                        background: #000000;
                        clip: true;

                        prop-flick := Flickable {
                            width: parent.width - 8px;
                            height: parent.height;
                            viewport-height: prop-entries.preferred-height;

                            prop-entries := VerticalLayout {
                                for entry in root.device-props: Rectangle {
                                    height: 22px;
                                    background: prop-row.has-hover ? #1E1E1E : #000000;
                                    prop-row := TouchArea {}
                                    HorizontalLayout {
                                        padding-left: 4px;
                                        padding-right: 4px;
                                        spacing: 0px;
                                        Text { text: entry.device;   color: #6699CC; font-size: 12px; vertical-alignment: center; width: root.dp-col1-width; overflow: elide; }
                                        Rectangle { width: 5px; }
                                        Text { text: entry.property; color: #CCCCCC; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                                        Rectangle { width: 5px; }
                                        Text { text: entry.value;    color: #AAAAAA; font-size: 12px; vertical-alignment: center; width: root.dp-col3-width; overflow: elide; }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            x: parent.width - 6px;
                            width: 6px;
                            height: parent.height;
                            background: #111111;
                            Rectangle {
                                visible: prop-flick.viewport-height > prop-flick.height;
                                width: 4px;
                                x: 1px;
                                y: (-prop-flick.viewport-y / prop-flick.viewport-height) * parent.height;
                                height: max(20px, (prop-flick.height / prop-flick.viewport-height) * parent.height);
                                background: #555555;
                                border-radius: 2px;
                            }
                        }
                    }
                }

                // Divider
                Rectangle { height: 1px; background: #444444; }

                // Bottom: tabbed panel
                VerticalLayout {
                    vertical-stretch: 1;

                    // Tab bar
                    Rectangle {
                        height: 28px;
                        background: #222222;
                        HorizontalLayout {
                            spacing: 0px;
                            alignment: start;

                            Rectangle {
                                width: 70px;
                                height: 28px;
                                background: root.active-tab == 0 ? #3A3A3A : #222222;
                                tab-proj-btn := TouchArea { clicked => { root.active-tab = 0; } }
                                Text {
                                    text: "Project";
                                    color: white;
                                    font-size: 13px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle {
                                width: 60px;
                                height: 28px;
                                background: root.active-tab == 1 ? #3A3A3A : #222222;
                                tab0-btn := TouchArea { clicked => { root.active-tab = 1; } }
                                Text {
                                    text: "Files";
                                    color: white;
                                    font-size: 13px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle {
                                width: 60px;
                                height: 28px;
                                background: root.active-tab == 2 ? #3A3A3A : #222222;
                                tab1-btn := TouchArea { clicked => { root.active-tab = 2; } }
                                Text {
                                    text: "Plots";
                                    color: white;
                                    font-size: 13px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle {
                                width: 60px;
                                height: 28px;
                                background: root.active-tab == 3 ? #3A3A3A : #222222;
                                tab2-btn := TouchArea { clicked => { root.active-tab = 3; } }
                                Text {
                                    text: "Help";
                                    color: white;
                                    font-size: 13px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Project tab
                    if root.active-tab == 0: VerticalLayout {
                        vertical-stretch: 1;

                        Rectangle {
                            vertical-stretch: 1;
                            background: #000000;
                            clip: true;

                            proj-flick := Flickable {
                                width: parent.width - 8px;
                                height: parent.height;
                                viewport-height: proj-entries.preferred-height;

                                proj-entries := VerticalLayout {
                                    for entry[i] in root.project-tree: Rectangle {
                                        height: 22px;
                                        background: root.selected-row == i ? #1E3A5F : #000000;
                                        row-ta := TouchArea {
                                            clicked => {
                                                root.selected-row = i;
                                                root.project-tree-selected(entry.object-id);
                                                if (entry.indent == 0) {
                                                    root.selected-project-id = entry.object-id;
                                                }
                                            }
                                        }
                                        HorizontalLayout {
                                            padding-left: 8px + entry.indent * 16px;
                                            padding-right: 4px;
                                            Text {
                                                text: entry.label;
                                                color: entry.indent == 0 ? #9ABFDD : #CCCCCC;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                                overflow: elide;
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                x: parent.width - 6px;
                                width: 6px;
                                height: parent.height;
                                background: #111111;
                                Rectangle {
                                    visible: proj-flick.viewport-height > proj-flick.height;
                                    width: 4px;
                                    x: 1px;
                                    y: (-proj-flick.viewport-y / proj-flick.viewport-height) * parent.height;
                                    height: max(20px, (proj-flick.height / proj-flick.viewport-height) * parent.height);
                                    background: #555555;
                                    border-radius: 2px;
                                }
                            }
                        }

                        Rectangle {
                            height: 32px;
                            background: #1A1A1A;
                            HorizontalLayout {
                                padding: 4px;
                                spacing: 6px;
                                alignment: start;

                                Rectangle {
                                    width: 60px; height: 24px;
                                    background: close-proj-btn.has-hover ? #3D3D3D : #2A2A2A;
                                    border-radius: 3px;
                                    close-proj-btn := TouchArea { clicked => { root.close-project(); } }
                                    Text { text: "Close"; color: white; font-size: 12px;
                                           horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }
                    }

                    // Files tab
                    if root.active-tab == 1: VerticalLayout {
                        vertical-stretch: 1;

                        // Path bar
                        Rectangle {
                            height: 26px;
                            background: #1E1E1E;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                spacing: 4px;

                                // Up button
                                Rectangle {
                                    width: 28px;
                                    background: up-btn.has-hover ? #3A3A3A : #2A2A2A;
                                    border-radius: 3px;
                                    up-btn := TouchArea {
                                        clicked => { root.navigate-to(".."); }
                                    }
                                    Text {
                                        text: "↑";
                                        color: #AAAAAA;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    text: root.current-path;
                                    color: #AAAAAA;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        Rectangle { height: 1px; background: #333333; }

                        // Table header
                        Rectangle {
                            height: 20px;
                            background: #000000;
                            HorizontalLayout {
                                padding-left: 24px;  // 8px margin + 12px icon + 4px gap
                                padding-right: 4px;
                                Text {
                                    text: "Name";
                                    color: #888888;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                Rectangle {
                                    width: 5px; height: parent.height;
                                    background: fh.pressed ? #666666 : (fh.has-hover ? #444444 : transparent);
                                    fh := TouchArea {
                                        mouse-cursor: col-resize;
                                        pointer-event(e) => { if (e.kind == PointerEventKind.down) { root.file-drag = self.mouse-x; } }
                                        moved => { root.file-size-width = max(40px, root.file-size-width - (self.mouse-x - root.file-drag)); }
                                    }
                                }
                                Text {
                                    text: "Size";
                                    color: #888888;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    width: root.file-size-width;
                                    horizontal-alignment: right;
                                }
                            }
                        }
                        Rectangle { height: 1px; background: #2A2A2A; }

                        // File list with custom scrollbar (Flickable avoids native frame)
                        Rectangle {
                            vertical-stretch: 1;
                            background: #000000;
                            clip: true;

                            file-flick := Flickable {
                                width: parent.width - 8px;
                                height: parent.height;
                                viewport-height: file-entries.preferred-height;

                                file-entries := VerticalLayout {
                                    for entry[i] in root.file-list: Rectangle {
                                        height: 22px;
                                        background: root.selected-file-row == i ? #1E3A5F
                                                  : entry-area.has-hover ? #1E1E1E : #000000;
                                        entry-area := TouchArea {
                                            clicked => {
                                                root.selected-file-row = i;
                                                root.selected-file-is-dir = entry.is-dir;
                                                if (entry.is-dir) {
                                                    root.selected-file-row = -1;
                                                    root.selected-file-is-dir = false;
                                                    root.navigate-to(entry.name);
                                                }
                                            }
                                        }
                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 4px;
                                            spacing: 4px;
                                            Text {
                                                text: entry.is-dir ? "▶" : " ";
                                                color: #6699CC;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                                width: 12px;
                                            }
                                            Text {
                                                text: entry.name;
                                                color: entry.is-dir ? #9ABFDD : #CCCCCC;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: entry.size;
                                                color: #777777;
                                                font-size: 12px;
                                                vertical-alignment: center;
                                                width: root.file-size-width;
                                                horizontal-alignment: right;
                                            }
                                        }
                                    }
                                }
                            }

                            // Custom scrollbar track
                            Rectangle {
                                x: parent.width - 6px;
                                width: 6px;
                                height: parent.height;
                                background: #111111;

                                // Thumb — only visible when content overflows
                                Rectangle {
                                    visible: file-flick.viewport-height > file-flick.height;
                                    width: 4px;
                                    x: 1px;
                                    y: (-file-flick.viewport-y / file-flick.viewport-height) * parent.height;
                                    height: max(20px, (file-flick.height / file-flick.viewport-height) * parent.height);
                                    background: #555555;
                                    border-radius: 2px;
                                }
                            }
                        }

                        Rectangle {
                            height: 32px;
                            background: #1A1A1A;
                            HorizontalLayout {
                                padding: 4px;
                                spacing: 6px;
                                alignment: start;

                                Rectangle {
                                    width: 60px; height: 24px;
                                    opacity: root.selected-file-row >= 0 && !root.selected-file-is-dir ? 1.0 : 0.4;
                                    background: open-file-btn.has-hover && root.selected-file-row >= 0 && !root.selected-file-is-dir ? #3D3D3D : #2A2A2A;
                                    border-radius: 3px;
                                    open-file-btn := TouchArea {
                                        clicked => {
                                            if (root.selected-file-row >= 0 && !root.selected-file-is-dir) {
                                                root.open-file(root.file-list[root.selected-file-row].name);
                                            }
                                        }
                                    }
                                    Text { text: "Open"; color: white; font-size: 12px;
                                           horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }
                    }

                    // Plots tab
                    if root.active-tab == 2: Rectangle {
                        vertical-stretch: 1;
                        background: #111111;
                    }

                    // Help tab
                    if root.active-tab == 3: Rectangle {
                        vertical-stretch: 1;
                        background: #111111;
                    }
                }
            }

        }
    }

    // ── Dismiss overlay (behind dropdowns) ───────────────────────────────────
    if root.file-menu-open || root.help-menu-open: Rectangle {
        z: 1;
        width: root.width;
        height: root.height;
        background: transparent;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.file-menu-open = false;
                root.help-menu-open = false;
            }
        }
    }

    // ── File dropdown ─────────────────────────────────────────────────────────
    if root.file-menu-open: Rectangle {
        z: 2;
        x: 4px;
        y: 36px;
        width: 120px;
        height: file-drop.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;

        file-drop := VerticalLayout {
            Rectangle {
                height: 30px;
                background: new-item.has-hover ? #3D3D3D : transparent;
                new-item := TouchArea {
                    clicked => {
                        root.file-menu-open = false;
                        root.new-project();
                    }
                }
                Text {
                    text: "New";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
            Rectangle {
                height: 30px;
                background: quit-item.has-hover ? #3D3D3D : transparent;
                quit-item := TouchArea {
                    clicked => { root.quit(); }
                }
                Text {
                    text: root.server-mode ? "Shut down server" : "Quit";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
        }
    }

    // ── Help dropdown ─────────────────────────────────────────────────────────
    if root.help-menu-open: Rectangle {
        z: 2;
        x: 66px;
        y: 36px;
        width: 120px;
        height: help-drop.preferred-height;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;

        help-drop := VerticalLayout {
            Rectangle {
                height: 30px;
                background: about-item.has-hover ? #3D3D3D : transparent;
                about-item := TouchArea {
                    clicked => {
                        root.help-menu-open = false;
                        root.about-open = true;
                    }
                }
                Text {
                    text: "About";
                    color: white;
                    height: parent.height;
                    vertical-alignment: center;
                    x: 8px;
                }
            }
        }
    }

    // ── Error backdrop ────────────────────────────────────────────────────────
    if root.error-message != "": Rectangle {
        z: 10;
        width: root.width;
        height: root.height;
        background: #00000080;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.error-message = ""; }
        }
    }

    // ── Error dialog ──────────────────────────────────────────────────────────
    if root.error-message != "": Rectangle {
        z: 11;
        width: 320px;
        height: err-layout.preferred-height + 48px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #884444;
        border-radius: 4px;

        TouchArea { width: parent.width; height: parent.height; }

        err-layout := VerticalLayout {
            padding: 24px;
            spacing: 8px;

            Text { text: "Cannot open file"; font-size: 16px; color: #FF6666; }
            Text { text: root.error-message; color: #CCCCCC; font-size: 12px; wrap: word-wrap; }
            Rectangle { height: 8px; }

            Rectangle {
                height: 32px;
                width: 60px;
                background: err-ok-btn.has-hover ? #3D3D3D : #444444;
                border-radius: 3px;
                err-ok-btn := TouchArea {
                    clicked => { root.error-message = ""; }
                }
                Text {
                    text: "OK";
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    // ── About backdrop ────────────────────────────────────────────────────────
    if root.about-open: Rectangle {
        z: 10;
        width: root.width;
        height: root.height;
        background: #00000080;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.about-open = false; }
        }
    }

    // ── About dialog ──────────────────────────────────────────────────────────
    if root.about-open: Rectangle {
        z: 11;
        width: 280px;
        height: about-layout.preferred-height + 48px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        background: #2B2B2B;
        border-width: 1px;
        border-color: #444444;
        border-radius: 4px;

        // absorb clicks so backdrop TouchArea doesn't fire
        TouchArea { width: parent.width; height: parent.height; }

        about-layout := VerticalLayout {
            padding: 24px;
            spacing: 8px;

            Text { text: "About"; font-size: 20px; color: white; }
            Text { text: "Work in progress"; color: white; }
            Rectangle { height: 8px; }

            Rectangle {
                height: 32px;
                width: 60px;
                background: ok-btn.has-hover ? #3D3D3D : #444444;
                border-radius: 3px;
                ok-btn := TouchArea {
                    clicked => { root.about-open = false; }
                }
                Text {
                    text: "OK";
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
