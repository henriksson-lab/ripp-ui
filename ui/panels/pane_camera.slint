import { RangeSlider } from "../widgets/range_slider.slint";
export global CameraGlobal {
    in property <image> camera-image;
    in-out property <bool>  live-snap: false;
    in-out property <float> camera-lo: 0.0;
    in-out property <float> camera-hi: 255.0;
    callback snap-requested();
    callback live-toggled(bool);
    callback camera-panned(float, float);
    callback camera-scrolled(float);
    callback camera-settings-changed();
}

export component PaneCamera inherits VerticalLayout {
    private property <float> drag-x;
    private property <float> drag-y;

    Rectangle {
        vertical-stretch: 1;
        Image {
            source: CameraGlobal.camera-image;
            image-fit: contain;
            width: 100%; height: 100%;
        }
        TouchArea {
            mouse-cursor: crosshair;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) {
                    root.drag-x = self.mouse-x / 1px;
                    root.drag-y = self.mouse-y / 1px;
                }
            }
            moved => {
                if (self.pressed) {
                    CameraGlobal.camera-panned(
                        self.mouse-x / 1px - root.drag-x,
                        self.mouse-y / 1px - root.drag-y
                    );
                    root.drag-x = self.mouse-x / 1px;
                    root.drag-y = self.mouse-y / 1px;
                }
            }
            scroll-event(e) => {
                CameraGlobal.camera-scrolled(e.delta-y / 1px);
                return EventResult.accept;
            }
        }
    }

    Rectangle {
        height: 32px;
        background: #1A1A1A;
        HorizontalLayout {
            padding: 4px; spacing: 6px; alignment: start;
            Rectangle {
                width: 60px; height: 24px;
                background: snap-btn.has-hover ? #3D3D3D : #2A2A2A;
                border-radius: 3px;
                snap-btn := TouchArea { clicked => { CameraGlobal.snap-requested(); } }
                Text { text: "Snap"; color: white; font-size: 12px;
                       horizontal-alignment: center; vertical-alignment: center; }
            }
            Rectangle {
                width: 60px; height: 24px;
                background: live-btn.has-hover ? #3D3D3D : #2A2A2A;
                border-radius: 3px;
                border-width: CameraGlobal.live-snap ? 1px : 0px;
                border-color: #6699CC;
                live-btn := TouchArea {
                    clicked => {
                        CameraGlobal.live-snap = !CameraGlobal.live-snap;
                        CameraGlobal.live-toggled(CameraGlobal.live-snap);
                    }
                }
                Text { text: "Live"; font-size: 12px;
                       color: CameraGlobal.live-snap ? #9ABFDD : white;
                       horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }

    Rectangle {
        height: 28px;
        background: #1A1A1A;
        HorizontalLayout {
            padding-left: 6px; padding-right: 6px;
            padding-top: 4px;  padding-bottom: 4px;
            RangeSlider {
                horizontal-stretch: 1;
                minimum: 0.0; maximum: 255.0;
                lo <=> CameraGlobal.camera-lo;
                hi <=> CameraGlobal.camera-hi;
                changed(l, h) => { CameraGlobal.camera-settings-changed(); }
            }
        }
    }
}
