import { Slider } from "std-widgets.slint";
import { ProjectTreeEntry } from "../types.slint";
import { RangeSlider } from "../widgets/range_slider.slint";
import { ProjectGlobal }  from "pane_project.slint";

export global Viewer2dGlobal {
    in property <image> viewer2d-image;
    in-out property <bool>  viewer2d-image-loaded: false;
    in-out property <float> viewer2d-lo: 0.0;
    in-out property <float> viewer2d-hi: 255.0;
    in-out property <float> viewer2d-z: 0;
    in-out property <float> viewer2d-z-max: 0;
    callback viewer2d-panned(float, float);
    callback viewer2d-scrolled(float);
    callback viewer2d-settings-changed();
    callback viewer2d-z-changed(float);
    callback viewer2d-object-selected(int, int);
    callback viewer2d-resized(float, float);
}

export component PaneViewer2d inherits VerticalLayout {
    private property <float>  drag-x;
    private property <float>  drag-y;
    private property <bool>   dd-open: false;
    private property <int>    dd-row: -1;
    private property <string> dd-label: "";
    private property <float>  cur-w: img-rect.width / 1px;
    private property <float>  cur-h: img-rect.height / 1px;
    changed cur-w => { Viewer2dGlobal.viewer2d-resized(self.cur-w, self.cur-h); }
    changed cur-h => { Viewer2dGlobal.viewer2d-resized(self.cur-w, self.cur-h); }

    HorizontalLayout {
        vertical-stretch: 1;

        img-rect := Rectangle {
            horizontal-stretch: 1;
            background: #111111;
            if Viewer2dGlobal.viewer2d-image-loaded: Image {
                source: Viewer2dGlobal.viewer2d-image;
                image-fit: fill;
                width: 100%; height: 100%;
            }
            if !Viewer2dGlobal.viewer2d-image-loaded: Text {
                text: "No image selected";
                color: #555555; font-size: 14px;
                horizontal-alignment: center; vertical-alignment: center;
            }
            TouchArea {
                mouse-cursor: crosshair;
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) {
                        root.drag-x = self.mouse-x / 1px;
                        root.drag-y = self.mouse-y / 1px;
                    }
                }
                moved => {
                    if (self.pressed) {
                        Viewer2dGlobal.viewer2d-panned(
                            self.mouse-x / 1px - root.drag-x,
                            self.mouse-y / 1px - root.drag-y
                        );
                        root.drag-x = self.mouse-x / 1px;
                        root.drag-y = self.mouse-y / 1px;
                    }
                }
                scroll-event(e) => {
                    Viewer2dGlobal.viewer2d-scrolled(e.delta-y / 1px);
                    return EventResult.accept;
                }
            }
        }

        Rectangle {
            width: 20px;
            background: #111111;
            Slider {
                width: 20px; height: parent.height;
                orientation: vertical;
                minimum: 0; maximum: Viewer2dGlobal.viewer2d-z-max;
                value <=> Viewer2dGlobal.viewer2d-z;
                enabled: Viewer2dGlobal.viewer2d-z-max > 0;
                changed(v) => { Viewer2dGlobal.viewer2d-z-changed(v); }
            }
        }
    }

    Rectangle {
        height: 28px;
        background: #1A1A1A;
        HorizontalLayout {
            padding-left: 6px; padding-right: 6px;
            padding-top: 4px;  padding-bottom: 4px;
            RangeSlider {
                horizontal-stretch: 1;
                minimum: 0.0; maximum: 255.0;
                lo <=> Viewer2dGlobal.viewer2d-lo;
                hi <=> Viewer2dGlobal.viewer2d-hi;
                changed(l, h) => { Viewer2dGlobal.viewer2d-settings-changed(); }
            }
        }
    }

    if root.dd-open: Rectangle {
        height: min(200px, dd-entries.preferred-height);
        background: #1E1E1E;
        border-width: 1px;
        border-color: #444444;
        clip: true;

        dd-flick := Flickable {
            width: parent.width; height: parent.height;
            viewport-height: dd-entries.preferred-height;

            dd-entries := VerticalLayout {
                for entry[i] in ProjectGlobal.project-tree: Rectangle {
                    height: 22px;
                    background: row-ta.has-hover ? #2A3A4A
                              : root.dd-row == i ? #1E3A5F : #1E1E1E;
                    row-ta := TouchArea {
                        clicked => {
                            root.dd-row = i;
                            root.dd-label = entry.label;
                            root.dd-open = false;
                            Viewer2dGlobal.viewer2d-object-selected(entry.project-id, entry.object-id);
                        }
                    }
                    HorizontalLayout {
                        padding-left: 8px + entry.indent * 16px;
                        padding-right: 4px;
                        Text {
                            text: entry.label;
                            color: entry.indent == 0 ? #9ABFDD : #CCCCCC;
                            font-size: 12px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        height: 32px;
        background: #1A1A1A;
        HorizontalLayout {
            padding: 4px;
            Rectangle {
                horizontal-stretch: 1; height: 24px;
                background: dd-btn.has-hover ? #3A3A3A : #2A2A2A;
                border-radius: 3px;
                dd-btn := TouchArea {
                    clicked => { root.dd-open = !root.dd-open; }
                }
                HorizontalLayout {
                    padding-left: 8px; padding-right: 8px;
                    Text {
                        text: root.dd-label == "" ? "Select object..." : root.dd-label;
                        color: root.dd-label == "" ? #666666 : #CCCCCC;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    Text { text: "▼"; color: #888888; font-size: 10px; vertical-alignment: center; }
                }
            }
        }
    }
}
