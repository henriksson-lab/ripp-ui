import { DynamicPane }  from "../widgets/dynamic_pane.slint";
import { LeftTabEntry } from "../types.slint";

// ── Right-top pane ─────────────────────────────────────────────────────────────

export component RightTopPane inherits Rectangle {
    in-out property <[LeftTabEntry]> tabs;
    in-out property <int> active-tab: 0;

    callback close-tab(int);
    callback move-tab(int, int);
    callback add-pane(int, int);
    callback tab-action(int, int);

    DynamicPane {
        width: 100%; height: 100%;
        tabs        <=> root.tabs;
        active-tab  <=> root.active-tab;
        current-area: 1;

        close-tab(i)     => { root.close-tab(i); }
        move-tab(i, t)   => { root.move-tab(i, t); }
        add-pane(a, t)   => { root.add-pane(a, t); }
        tab-action(i, a) => { root.tab-action(i, a); }
    }
}

// ── Right-bottom pane ──────────────────────────────────────────────────────────

export component RightBottomPane inherits Rectangle {
    in-out property <[LeftTabEntry]> tabs;
    in-out property <int> active-tab: 0;

    callback close-tab(int);
    callback move-tab(int, int);
    callback add-pane(int, int);
    callback tab-action(int, int);

    DynamicPane {
        width: 100%; height: 100%;
        tabs        <=> root.tabs;
        active-tab  <=> root.active-tab;
        current-area: 2;

        close-tab(i)     => { root.close-tab(i); }
        move-tab(i, t)   => { root.move-tab(i, t); }
        add-pane(a, t)   => { root.add-pane(a, t); }
        tab-action(i, a) => { root.tab-action(i, a); }
    }
}
