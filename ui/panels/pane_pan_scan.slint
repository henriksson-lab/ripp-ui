import { LineEdit } from "std-widgets.slint";
import { RangeSlider } from "../widgets/range_slider.slint";
export global PanScanGlobal {
    in property <image>  panscan-image;
    in-out property <float>  panscan-lo: 0.0;
    in-out property <float>  panscan-hi: 255.0;
    in-out property <string> panscan-min-x: "";
    in-out property <string> panscan-max-x: "";
    in-out property <string> panscan-min-y: "";
    in-out property <string> panscan-max-y: "";
    callback panscan-panned(float, float);
    callback panscan-scrolled(float);
    callback panscan-settings-changed();
    callback panscan-set-corner();
    callback panscan-reset();
    callback panscan-record();
    callback panscan-field-edited(int, string);
}

export component PanePanScan inherits VerticalLayout {
    private property <float> drag-x;
    private property <float> drag-y;

    Rectangle {
        vertical-stretch: 1;
        background: #111111;
        Image {
            source: PanScanGlobal.panscan-image;
            image-fit: fill;
            width: 100%; height: 100%;
        }
        TouchArea {
            mouse-cursor: crosshair;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) {
                    root.drag-x = self.mouse-x / 1px;
                    root.drag-y = self.mouse-y / 1px;
                }
            }
            moved => {
                if (self.pressed) {
                    PanScanGlobal.panscan-panned(
                        self.mouse-x / 1px - root.drag-x,
                        self.mouse-y / 1px - root.drag-y
                    );
                    root.drag-x = self.mouse-x / 1px;
                    root.drag-y = self.mouse-y / 1px;
                }
            }
            scroll-event(e) => {
                PanScanGlobal.panscan-scrolled(e.delta-y / 1px);
                return EventResult.accept;
            }
        }
    }

    Rectangle {
        height: 28px;
        background: #1A1A1A;
        HorizontalLayout {
            padding-left: 6px; padding-right: 6px;
            padding-top: 4px;  padding-bottom: 4px;
            RangeSlider {
                horizontal-stretch: 1;
                minimum: 0.0; maximum: 255.0;
                lo <=> PanScanGlobal.panscan-lo;
                hi <=> PanScanGlobal.panscan-hi;
                changed(l, h) => { PanScanGlobal.panscan-settings-changed(); }
            }
        }
    }

    Rectangle {
        background: #1A1A1A;
        VerticalLayout {
            padding: 6px; spacing: 4px;
            HorizontalLayout { spacing: 6px; height: 24px;
                Text { text: "Min X"; color: #AAAAAA; font-size: 12px; vertical-alignment: center; width: 44px; }
                LineEdit { horizontal-stretch: 1; text <=> PanScanGlobal.panscan-min-x; font-size: 12px;
                           edited(t) => { PanScanGlobal.panscan-field-edited(0, t); } }
                Text { text: "Max X"; color: #AAAAAA; font-size: 12px; vertical-alignment: center; width: 44px; }
                LineEdit { horizontal-stretch: 1; text <=> PanScanGlobal.panscan-max-x; font-size: 12px;
                           edited(t) => { PanScanGlobal.panscan-field-edited(1, t); } }
            }
            HorizontalLayout { spacing: 6px; height: 24px;
                Text { text: "Min Y"; color: #AAAAAA; font-size: 12px; vertical-alignment: center; width: 44px; }
                LineEdit { horizontal-stretch: 1; text <=> PanScanGlobal.panscan-min-y; font-size: 12px;
                           edited(t) => { PanScanGlobal.panscan-field-edited(2, t); } }
                Text { text: "Max Y"; color: #AAAAAA; font-size: 12px; vertical-alignment: center; width: 44px; }
                LineEdit { horizontal-stretch: 1; text <=> PanScanGlobal.panscan-max-y; font-size: 12px;
                           edited(t) => { PanScanGlobal.panscan-field-edited(3, t); } }
            }
            HorizontalLayout { spacing: 6px; height: 24px;
                Rectangle {
                    width: 90px; height: 24px; border-radius: 3px;
                    background: sc-btn.has-hover ? #3D3D3D : #2A2A2A;
                    sc-btn := TouchArea { clicked => { PanScanGlobal.panscan-set-corner(); } }
                    Text { text: "Set corner"; color: white; font-size: 12px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 60px; height: 24px; border-radius: 3px;
                    background: rst-btn.has-hover ? #3D3D3D : #2A2A2A;
                    rst-btn := TouchArea { clicked => { PanScanGlobal.panscan-reset(); } }
                    Text { text: "Reset"; color: white; font-size: 12px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 130px; height: 24px; border-radius: 3px;
                    background: rec-btn.has-hover ? #3D3D3D : #2A2A2A;
                    rec-btn := TouchArea { clicked => { PanScanGlobal.panscan-record(); } }
                    Text { text: "Record panorama"; color: white; font-size: 12px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }
}
